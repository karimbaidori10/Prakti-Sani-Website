<div class="page-header sheet-hero">
    <div>
        <h1>Dokument bearbeiten</h1>
        <p>Bearbeite Titel, Kategorie, Link und Hinweise des Dokuments.</p>
    </div>

    <div class="sheet-hero-count">
        <strong>DOC</strong>
        <span>Admin</span>
    </div>
</div>

<section class="edit-page-layout">
    <div class="card admin-glow edit-main-card">
        <div class="card-header">
            <div>
                <h2>Dokumentdaten</h2>
                <p class="card-subtitle">Passe gespeicherte Unterlagen oder Google-Docs-Links an.</p>
            </div>

            <span class="chip blue">Admin</span>
        </div>

        <form action="/dokumente/edit/<%= doc._id %>" method="POST" class="form edit-form">
            <label>
                <span>Titel</span>
                <input
                    type="text"
                    name="title"
                    placeholder="Titel des Dokuments"
                    value="<%= doc.title || '' %>"
                    required
                >
            </label>

            <label>
                <span>Kategorie</span>
                <select name="type" required>
                    <option value="">Kategorie ausw&auml;hlen</option>

                    <option value="LSMD Dienstblatt" <%= doc.type === "LSMD Dienstblatt" ? "selected" : "" %>>
                        LSMD Dienstblatt
                    </option>

                    <option value="Einstellungs-Checkliste" <%= doc.type === "Einstellungs-Checkliste" ? "selected" : "" %>>
                        Einstellungs-Checkliste
                    </option>

                    <option value="Prakti darf alleine" <%= doc.type === "Prakti darf alleine" ? "selected" : "" %>>
                        Prakti darf alleine
                    </option>

                    <option value="Sani Leitfaden" <%= doc.type === "Sani Leitfaden" ? "selected" : "" %>>
                        Sani Leitfaden
                    </option>

                    <option value="Sanitaeter Theorie" <%= doc.type === "Sanitaeter Theorie" ? "selected" : "" %>>
                        Sanit&auml;ter Theorie
                    </option>

                    <option value="Dienstvorschrift LSMD" <%= doc.type === "Dienstvorschrift LSMD" ? "selected" : "" %>>
                        Dienstvorschrift LSMD
                    </option>

                    <option value="Prakti Sani Regelwerk" <%= doc.type === "Prakti Sani Regelwerk" ? "selected" : "" %>>
                        Prakti Sani Regelwerk
                    </option>
                </select>
            </label>

            <label>
                <span>Dokument-Link</span>
                <input
                    type="url"
                    name="url"
                    placeholder="Dokument-Link / Google Docs Link"
                    value="<%= doc.url || '' %>"
                    required
                >
            </label>

            <label>
                <span>Hinweise</span>
                <textarea name="notes" placeholder="Kurze Beschreibung oder Hinweise"><%= doc.notes || '' %></textarea>
            </label>

            <div class="edit-actions">
                <button type="submit">Änderungen speichern</button>

                <a href="/dokumente" class="open-doc-btn">
                    Zur&uuml;ck
                </a>
            </div>
        </form>
    </div>

    <div class="card clean-panel edit-side-card">
        <div class="card-header">
            <div>
                <h2>Dokumentstatus</h2>
                <p class="card-subtitle">Aktuelle gespeicherte Daten.</p>
            </div>

            <span class="chip green">Gespeichert</span>
        </div>

        <div class="clean-status-list">
            <div>
                <span>Titel</span>
                <strong><%= doc.title || "Unbenannt" %></strong>
            </div>

            <div>
                <span>Kategorie</span>
                <strong>
                    <% if (doc.type === "Sanitaeter Theorie") { %>
                        Sanit&auml;ter Theorie
                    <% } else { %>
                        <%= doc.type || "Dokument" %>
                    <% } %>
                </strong>
            </div>

            <div>
                <span>Link</span>
                <strong>Vorhanden</strong>
            </div>

            <div>
                <span>Rechte</span>
                <strong>Admin</strong>
            </div>
        </div>

        <div class="clean-divider"></div>

        <a href="<%= doc.url %>" target="_blank" rel="noopener noreferrer" class="open-doc-btn">
            Dokument &ouml;ffnen
        </a>
    </div>
</section>