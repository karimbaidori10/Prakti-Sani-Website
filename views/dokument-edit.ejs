<div class="page-header">
    <h1>✏️ Dokument bearbeiten</h1>
    <p>Bearbeite Titel, Kategorie, Link und Hinweise des Dokuments.</p>
</div>

<section class="card">
    <div class="card-header">
        <h2>📄 Dokumentdaten</h2>
        <span class="chip blue">Admin</span>
    </div>

    <form action="/dokumente/edit/<%= doc._id %>" method="POST" class="form">
        <input
            type="text"
            name="title"
            placeholder="Titel des Dokuments"
            value="<%= doc.title || '' %>"
            required
        >

        <select name="type" required>
            <option value="">Kategorie auswählen</option>
            <option value="Leitfaden" <%= doc.type === "Leitfaden" ? "selected" : "" %>>Leitfaden</option>
            <option value="Formular" <%= doc.type === "Formular" ? "selected" : "" %>>Formular</option>
            <option value="SOP" <%= doc.type === "SOP" ? "selected" : "" %>>SOP</option>
            <option value="Prüfung" <%= doc.type === "Prüfung" ? "selected" : "" %>>Prüfung</option>
            <option value="Google Docs" <%= doc.type === "Google Docs" ? "selected" : "" %>>Google Docs</option>
            <option value="Sonstiges" <%= doc.type === "Sonstiges" ? "selected" : "" %>>Sonstiges</option>
        </select>

        <input
            type="url"
            name="url"
            placeholder="Dokument-Link / Google Docs Link"
            value="<%= doc.url || '' %>"
            required
        >

        <textarea name="notes" placeholder="Kurze Beschreibung oder Hinweise"><%= doc.notes || '' %></textarea>

        <div class="doc-actions">
            <button type="submit">Änderungen speichern</button>

            <a href="/dokumente" class="open-doc-btn">
                Abbrechen
            </a>
        </div>
    </form>
</section>
