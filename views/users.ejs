
<div class="page-header">
    <h1>Mitglieder</h1>
    <p>Alle Mitglieder mit Punkten, Wochenziel und Ranguebersicht.</p>
</div>

<section class="stats-grid">
    <div class="stat-card stat-blue">
        <div class="stat-icon">User</div>
        <div>
            <h2><%= users ? users.length : 0 %></h2>
            <strong>Mitglieder</strong>
            <p>Mit Punkte-Eintrag</p>
        </div>
    </div>

    <div class="stat-card stat-green">
        <div class="stat-icon">OK</div>
        <div>
            <h2><%= users ? users.filter(u => Number(u.points || 0) >= 5).length : 0 %></h2>
            <strong>Wochenziel</strong>
            <p>Erreicht</p>
        </div>
    </div>

    <div class="stat-card stat-yellow">
        <div class="stat-icon">Offen</div>
        <div>
            <h2><%= users ? users.filter(u => Number(u.points || 0) < 5).length : 0 %></h2>
            <strong>Offen</strong>
            <p>Noch unter 5 Punkte</p>
        </div>
    </div>

    <div class="stat-card stat-red">
        <div class="stat-icon">Top</div>
        <div>
            <h2><%= users && users.length > 0 ? users[0].points : 0 %></h2>
            <strong>Top Punkte</strong>
            <p>Bester Eintrag</p>
        </div>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2>Mitgliederuebersicht</h2>
        <span class="chip blue"><%= users ? users.length : 0 %> Mitglieder</span>
    </div>

    <% if (!users || users.length === 0) { %>
        <div class="empty-state">
            <div>Keine Daten</div>
            <h3>Keine Mitglieder vorhanden</h3>
            <p>Sobald Punkte vergeben werden, erscheinen Mitglieder hier automatisch.</p>
        </div>
    <% } else { %>

        <div class="members-grid">
            <% users.forEach((member, index) => { %>
                <div class="member-card <%= index === 0 ? 'top-member' : '' %>">
                    <div class="member-rank">
                        <% if (index === 0) { %>
                            Platz 1
                        <% } else if (index === 1) { %>
                            Platz 2
                        <% } else if (index === 2) { %>
                            Platz 3
                        <% } else { %>
                            #<%= index + 1 %>
                        <% } %>
                    </div>

                    <div class="member-avatar">
                        <%= member.userId ? member.userId.toString().charAt(0).toUpperCase() : "?" %>
                    </div>

                    <div class="member-info">
                        <h3><%= member.displayName || ("User " + (index + 1)) %></h3>
<p>Rang: <%= member.rank || "Kein Rang" %></p>
<p>Discord ID: <%= member.userId %></p>
                    </div>

                    <div class="member-points">
                        <strong><%= member.points || 0 %></strong>
                        <span>Punkte</span>
                    </div>

                    <div class="member-goal">
                        <% if (Number(member.points || 0) >= 5) { %>
                            <span class="badge success">Wochenziel erreicht</span>
                        <% } else { %>
                            <span class="badge warning">Noch offen</span>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

    <% } %>
</section>
