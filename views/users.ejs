<div class="page-header">
    <h1>Mitglieder</h1>
    <p>Alle Mitglieder mit Punkten, Wochenziel, Rang und Discord-&Uuml;bersicht.</p>
</div>

<section class="stats-grid">
    <div class="stat-card stat-blue">
        <div class="stat-icon">👥</div>
        <div>
            <h2><%= users ? users.length : 0 %></h2>
            <strong>Mitglieder</strong>
            <p>Aktive Eintr&auml;ge</p>
        </div>
    </div>

    <div class="stat-card stat-green">
        <div class="stat-icon">✅</div>
        <div>
            <h2><%= users ? users.filter(u => Number(u.points || 0) >= 5).length : 0 %></h2>
            <strong>Wochenziel</strong>
            <p>5+ Punkte erreicht</p>
        </div>
    </div>

    <div class="stat-card stat-yellow">
        <div class="stat-icon">⏳</div>
        <div>
            <h2><%= users ? users.filter(u => Number(u.points || 0) < 5).length : 0 %></h2>
            <strong>Noch offen</strong>
            <p>Unter 5 Punkte</p>
        </div>
    </div>

    <div class="stat-card stat-red">
        <div class="stat-icon">🏆</div>
        <div>
            <h2><%= users && users.length > 0 ? users[0].points : 0 %></h2>
            <strong>Top Punkte</strong>
            <p>St&auml;rkster Eintrag</p>
        </div>
    </div>
</section>

<section class="card" style="margin-top: 18px;">
    <div class="card-header">
        <div>
            <h2>Mitglieder&uuml;bersicht</h2>
            <p class="card-subtitle">Suche nach Name, Rang, Discord ID oder Punkten.</p>
        </div>

        <span class="chip blue">
            <span id="memberCount"><%= users ? users.length : 0 %></span> Mitglieder
        </span>
    </div>

    <% if (!users || users.length === 0) { %>
        <div class="empty-state">
            <div>👥</div>
            <h3>Keine Mitglieder vorhanden</h3>
            <p>Sobald Punkte vergeben werden, erscheinen Mitglieder hier automatisch.</p>
        </div>
    <% } else { %>

        <div class="pro-searchbar">
            <input
                type="text"
                id="memberSearch"
                placeholder="Mitglied suchen..."
                autocomplete="off"
            >

            <select id="memberFilter">
                <option value="all">Alle Mitglieder</option>
                <option value="done">Wochenziel erreicht</option>
                <option value="open">Wochenziel offen</option>
            </select>
        </div>

        <div class="member-table">
            <div class="member-table-head">
                <span>Platz</span>
                <span>Mitglied</span>
                <span>Rang</span>
                <span>Punkte</span>
                <span>Wochenziel</span>
            </div>

            <% users.forEach((member, index) => { %>
                <%
                    const points = Number(member.points || 0);
                    const goalDone = points >= 5;
                    const displayName = member.displayName || member.username || ("User " + (index + 1));
                    const firstLetter = displayName.toString().charAt(0).toUpperCase();
                %>

                <div
                    class="member-table-row <%= index === 0 ? 'top-member-row' : '' %>"
                    data-search="<%= [
                        displayName || '',
                        member.username || '',
                        member.rank || '',
                        member.userId || '',
                        points
                    ].join(' ').toLowerCase() %>"
                    data-goal="<%= goalDone ? 'done' : 'open' %>"
                >
                    <div class="member-place">
                        <% if (index === 0) { %>
                            🏆
                        <% } else { %>
                            <%= index + 1 %>
                        <% } %>
                    </div>

                    <div class="member-profile">
                        <div class="member-avatar-img">
                            <% if (member.avatarUrl) { %>
                                <img src="<%= member.avatarUrl %>" alt="Avatar">
                            <% } else { %>
                                <span><%= firstLetter || "?" %></span>
                            <% } %>
                        </div>

                        <div>
                            <h3><%= displayName %></h3>
                            <p>Discord ID: <%= member.userId || "Nicht vorhanden" %></p>
                        </div>
                    </div>

                    <div class="member-rank-text">
                        <%= member.rank || "Kein Rang" %>
                    </div>

                    <div class="member-points-text">
                        <strong><%= points %></strong>
                        <span>Punkte</span>
                    </div>

                    <div class="member-goal">
                        <% if (goalDone) { %>
                            <span class="badge success">Erreicht</span>
                        <% } else { %>
                            <span class="badge warning">Noch <%= 5 - points %> offen</span>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

        <div id="memberEmptySearch" class="empty-state" style="display:none; margin-top: 16px;">
            <div>🔍</div>
            <h3>Kein Mitglied gefunden</h3>
            <p>Versuche einen anderen Namen, Rang oder eine Discord ID.</p>
        </div>

    <% } %>
</section>

<script>
    const memberSearch = document.getElementById("memberSearch");
    const memberFilter = document.getElementById("memberFilter");
    const memberRows = Array.from(document.querySelectorAll(".member-table-row"));
    const memberCount = document.getElementById("memberCount");
    const memberEmptySearch = document.getElementById("memberEmptySearch");

    function filterMembers() {
        const query = (memberSearch?.value || "").toLowerCase().trim();
        const filter = memberFilter?.value || "all";

        let visible = 0;

        memberRows.forEach(row => {
            const searchText = row.dataset.search || "";
            const goal = row.dataset.goal || "open";

            const matchesSearch = searchText.includes(query);
            const matchesFilter = filter === "all" || goal === filter;

            const show = matchesSearch && matchesFilter;

            row.style.display = show ? "" : "none";

            if (show) {
                visible++;
            }
        });

        if (memberCount) {
            memberCount.textContent = visible;
        }

        if (memberEmptySearch) {
            memberEmptySearch.style.display = visible === 0 ? "block" : "none";
        }
    }

    if (memberSearch) {
        memberSearch.addEventListener("input", filterMembers);
    }

    if (memberFilter) {
        memberFilter.addEventListener("change", filterMembers);
    }
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const memberSearch = document.getElementById("memberSearch");
    const memberFilter = document.getElementById("memberFilter");
    const memberRows = Array.from(document.querySelectorAll(".member-table-row"));
    const memberCount = document.getElementById("memberCount");

    function filterMembers() {
        const searchValue = memberSearch ? memberSearch.value.toLowerCase().trim() : "";
        const filterValue = memberFilter ? memberFilter.value : "all";

        let visibleCount = 0;

        memberRows.forEach((row) => {
            const searchText = (row.getAttribute("data-search") || "").toLowerCase();
            const goalStatus = row.getAttribute("data-goal") || "open";

            const matchesSearch = searchText.includes(searchValue);
            const matchesFilter = filterValue === "all" || goalStatus === filterValue;

            if (matchesSearch && matchesFilter) {
                row.style.setProperty("display", "grid", "important");
                visibleCount++;
            } else {
                row.style.setProperty("display", "none", "important");
            }
        });

        if (memberCount) {
            memberCount.textContent = visibleCount;
        }
    }

    if (memberSearch) {
        memberSearch.addEventListener("input", filterMembers);
    }

    if (memberFilter) {
        memberFilter.addEventListener("change", filterMembers);
    }

    filterMembers();
});
</script>