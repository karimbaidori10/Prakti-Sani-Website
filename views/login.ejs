<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LSMD Abteilungszentrale Login</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="ultra-login-body">

    <div class="ultra-grid"></div>
    <div class="ultra-orb ultra-orb-red"></div>
    <div class="ultra-orb ultra-orb-blue"></div>
    <div class="ultra-orb ultra-orb-green"></div>

    <main class="ultra-login-wrapper">
        <section class="ultra-login-card">
            <div class="ultra-logo">
                <span>🚑</span>
            </div>

            <div class="ultra-access-badge">
                LSMD ACCESS SYSTEM
            </div>

            <h1>
                LSMD Abteilungszentrale<br>
                Dashboard
            </h1>

            <p class="ultra-login-text">
                Melde dich mit Discord an und verwalte Ausbildungstermine,
                Mitglieder, Dokumente und spontane Pr&uuml;fungen zentral im LSMD-System.
            </p>

            <a href="/auth/discord" class="ultra-discord-btn">
                <span>💬</span>
                Mit Discord einloggen
            </a>

            <div class="ultra-role-grid">
                <div>
                    <strong>Admin</strong>
                    <p>Voller Zugriff</p>
                </div>

                <div>
                    <strong>LSMD Abteilungszentrale</strong>
                    <p>Dashboard Zugriff</p>
                </div>
            </div>

            <p class="ultra-small-note">
                Zugriff nur mit g&uuml;ltiger Discord-Rolle.
            </p>
        </section>

        <section class="ultra-info-panel">
            <div class="ultra-panel-top">
                <span>LIVE SYSTEM</span>
                <strong>Online</strong>
            </div>

            <h2>Abteilungen. Verwaltung. Kontrolle.</h2>

            <p>
                Die LSMD Abteilungszentrale verbindet Discord-Login,
                Rollenpr&uuml;fung, Punkteverwaltung, Dokumente und MD-Eintr&auml;ge
                in einem modernen System.
            </p>

            <div class="ultra-feature-stack">
                <div class="ultra-feature-card">
                    <span>📅</span>
                    <div>
                        <strong>Ausbildungstermine</strong>
                        <p>Fahrfreigaben und Sanit&auml;ter-Pr&uuml;fungen sauber dokumentieren.</p>
                    </div>
                </div>

                <div class="ultra-feature-card">
                    <span>👥</span>
                    <div>
                        <strong>Mitglieder & Punkte</strong>
                        <p>Wochenziel, Rang und Punkteverwaltung auf einen Blick.</p>
                    </div>
                </div>

                <div class="ultra-feature-card">
                    <span>📄</span>
                    <div>
                        <strong>Dokumente</strong>
                        <p>Leitf&auml;den, Regelwerke und Checklisten zentral abrufen.</p>
                    </div>
                </div>

                <div class="ultra-feature-card">
                    <span>🛡️</span>
                    <div>
                        <strong>Admin Tools</strong>
                        <p>Spontane-Pr&uuml;fungen Panel direkt per Discord senden.</p>
                    </div>
                </div>
            </div>

            <div class="ultra-system-row">
                <div>
                    <strong>Discord</strong>
                    <span>Verbunden</span>
                </div>

                <div>
                    <strong>MongoDB</strong>
                    <span>Online</span>
                </div>

                <div>
                    <strong>LSMD</strong>
                    <span>Bereit</span>
                </div>
            </div>
        </section>
    </main>

</body>
</html>