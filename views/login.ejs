<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>LSMD Login</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="login-page">

<div class="login-shell">
    <div class="login-bg-orb orb-red"></div>
    <div class="login-bg-orb orb-blue"></div>

    <div class="login-card pro-login">
        <div class="login-logo">+</div>

        <div class="login-title">
            <span>LSMD ACCESS</span>
            <h1>Prakti-Sani Dashboard</h1>
            <p>Einloggen mit Discord-Rollenpruefung</p>
        </div>

        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>

        <a href="/auth/discord" class="discord-login">
            <span>Discord</span>
            Mit Discord einloggen
        </a>

        <div class="login-access-box">
            <div>
                <strong>Admin</strong>
                <p>Voller Zugriff</p>
            </div>

            <div>
                <strong>Prakti-Sani</strong>
                <p>Dashboard Zugriff</p>
            </div>
        </div>

        <div class="login-hint">
            Zugriff nur mit gueltiger Discord-Rolle.
        </div>
    </div>
</div>

</body>
</html>