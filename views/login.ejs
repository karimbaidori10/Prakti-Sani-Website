<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LSMD Abteilungszentrale Login</title>

    <style>
    * {
        box-sizing: border-box;
    }

    :root {
        --bg: #020617;
        --card: rgba(15, 23, 42, 0.72);
        --card2: rgba(2, 6, 23, 0.58);
        --line: rgba(148, 163, 184, 0.16);
        --text: #f8fafc;
        --muted: rgba(226, 232, 240, 0.68);
        --blue: #2563eb;
        --cyan: #06b6d4;
        --red: #ef233c;
        --green: #22c55e;
    }

    body {
        margin: 0;
        min-height: 100vh;
        font-family: Inter, Arial, sans-serif;
        color: var(--text);
        background:
            radial-gradient(circle at 18% 20%, rgba(239, 35, 60, 0.20), transparent 28%),
            radial-gradient(circle at 82% 18%, rgba(37, 99, 235, 0.26), transparent 34%),
            linear-gradient(135deg, #020617 0%, #050816 48%, #020617 100%);
        overflow: hidden;
    }

    body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 46px 46px;
        opacity: 0.75;
        animation: gridMove 20s linear infinite;
        pointer-events: none;
    }

    body::after {
        content: "";
        position: fixed;
        width: 420px;
        height: 420px;
        right: -130px;
        bottom: -160px;
        border-radius: 999px;
        background: rgba(6, 182, 212, 0.14);
        filter: blur(70px);
        pointer-events: none;
    }

    .orb {
        position: fixed;
        border-radius: 999px;
        filter: blur(75px);
        pointer-events: none;
        opacity: 0.55;
    }

    .orb.red {
        width: 360px;
        height: 360px;
        left: -130px;
        bottom: -120px;
        background: rgba(239, 35, 60, 0.30);
    }

    .orb.blue {
        width: 430px;
        height: 430px;
        right: -130px;
        top: -150px;
        background: rgba(37, 99, 235, 0.34);
    }

    .page {
        position: relative;
        z-index: 2;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
    }

    .command-shell {
        width: min(1080px, 100%);
        min-height: 620px;
        display: grid;
        grid-template-columns: 420px 1fr;
        border-radius: 34px;
        overflow: hidden;
        background: rgba(15, 23, 42, 0.50);
        border: 1px solid rgba(148, 163, 184, 0.18);
        box-shadow:
            0 36px 120px rgba(0, 0, 0, 0.60),
            inset 0 1px 0 rgba(255, 255, 255, 0.06);
        backdrop-filter: blur(22px);
    }

    .panel {
        position: relative;
        overflow: hidden;
    }

    .login-panel {
        padding: 34px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        background:
            radial-gradient(circle at top left, rgba(239, 35, 60, 0.16), transparent 36%),
            rgba(2, 6, 23, 0.36);
        border-right: 1px solid rgba(148, 163, 184, 0.14);
    }

    .hero-panel {
        padding: 34px;
        background:
            radial-gradient(circle at top right, rgba(37, 99, 235, 0.18), transparent 38%),
            rgba(15, 23, 42, 0.26);
    }

    .brand-row {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
    }

    .brand-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        font-size: 27px;
        background: linear-gradient(135deg, #ef233c, #991b1b);
        box-shadow: 0 18px 45px rgba(239, 35, 60, 0.38);
        animation: pulse 3s ease-in-out infinite;
    }

    .brand-title {
        line-height: 1.1;
    }

    .brand-title strong {
        display: block;
        font-size: 15px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .brand-title span {
        color: var(--muted);
        font-size: 12px;
        font-weight: 700;
    }

    .kicker {
        display: inline-flex;
        width: fit-content;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(239, 68, 68, 0.10);
        border: 1px solid rgba(248, 113, 113, 0.25);
        color: #fecaca;
        font-size: 10px;
        font-weight: 950;
        letter-spacing: 0.15em;
        text-transform: uppercase;
    }

    h1 {
        margin: 16px 0 12px;
        font-size: 44px;
        line-height: 0.94;
        letter-spacing: -0.06em;
        font-weight: 1000;
    }

    .hero-title {
        max-width: 560px;
        font-size: 54px;
        margin-top: 20px;
    }

    .login-panel p,
    .hero-panel p {
        margin: 0;
        color: var(--muted);
        line-height: 1.55;
        font-size: 14px;
    }

    .login-btn {
        margin-top: 26px;
        height: 54px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        color: white;
        font-size: 16px;
        font-weight: 950;
        background: linear-gradient(135deg, #6366f1, #2563eb, #06b6d4);
        box-shadow: 0 18px 40px rgba(37, 99, 235, 0.38);
        transition: 0.22s ease;
    }

    .login-btn:hover {
        transform: translateY(-3px);
        filter: brightness(1.08);
        box-shadow: 0 24px 60px rgba(37, 99, 235, 0.52);
    }

    .access-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 18px;
    }

    .access-card,
    .feature-card,
    .status-card,
    .preview-card {
        border-radius: 17px;
        padding: 14px;
        background: rgba(2, 6, 23, 0.42);
        border: 1px solid rgba(148, 163, 184, 0.13);
        transition: 0.22s ease;
    }

    .access-card:hover,
    .feature-card:hover,
    .status-card:hover,
    .preview-card:hover {
        transform: translateY(-3px);
        border-color: rgba(96, 165, 250, 0.32);
        background: rgba(15, 23, 42, 0.68);
    }

    .access-card h3,
    .feature-card h3,
    .status-card h3,
    .preview-card h3 {
        margin: 0 0 5px;
        font-size: 15px;
        font-weight: 950;
    }

    .access-card span,
    .feature-card p,
    .status-card span,
    .preview-card p {
        margin: 0;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.45;
        font-weight: 650;
    }

    .small-note {
        margin-top: 20px;
        color: rgba(226, 232, 240, 0.48);
        font-size: 11px;
        text-align: center;
    }

    .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .online {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #86efac;
        font-size: 12px;
        font-weight: 900;
    }

    .online::before {
        content: "";
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: var(--green);
        box-shadow: 0 0 16px var(--green);
    }

    .feature-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 24px;
    }

    .feature-card {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        min-height: 92px;
    }

    .feature-icon {
        width: 40px;
        height: 40px;
        border-radius: 13px;
        display: grid;
        place-items: center;
        background: rgba(37, 99, 235, 0.18);
        border: 1px solid rgba(96, 165, 250, 0.24);
        font-size: 19px;
        flex: 0 0 40px;
    }

    .status-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-top: 18px;
    }

    .status-card strong {
        color: #86efac;
        font-size: 12px;
    }

    .preview-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 24px;
    }

    .preview-card {
        min-height: 118px;
        position: relative;
        overflow: hidden;
    }

    .preview-card::after {
        content: "";
        position: absolute;
        inset: auto 12px 12px 12px;
        height: 6px;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--red), var(--blue), var(--cyan));
        opacity: 0.55;
    }

    .preview-card .number {
        font-size: 28px;
        font-weight: 1000;
        margin-top: 10px;
    }

    .scanline {
        position: absolute;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(96,165,250,0.75), transparent);
        top: 0;
        animation: scan 6s linear infinite;
        opacity: 0.45;
    }

    @keyframes scan {
        from { top: 0; }
        to { top: 100%; }
    }

    @keyframes pulse {
        0%, 100% { box-shadow: 0 18px 45px rgba(239, 35, 60, 0.38); }
        50% { box-shadow: 0 24px 70px rgba(239, 35, 60, 0.56); }
    }

    @keyframes gridMove {
        from { background-position: 0 0; }
        to { background-position: 46px 46px; }
    }

    @media (max-width: 980px) {
        body {
            overflow: auto;
        }

        .command-shell {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .login-panel {
            border-right: none;
            border-bottom: 1px solid rgba(148, 163, 184, 0.14);
        }

        .hero-title {
            font-size: 44px;
        }
    }

    @media (max-width: 620px) {
        .page {
            padding: 14px;
        }

        .login-panel,
        .hero-panel {
            padding: 24px;
        }

        h1 {
            font-size: 38px;
        }

        .hero-title {
            font-size: 38px;
        }

        .access-grid,
        .feature-grid,
        .status-grid,
        .preview-row {
            grid-template-columns: 1fr;
        }
    }
</style>
</head>

<body>
    <div class="orb red"></div>
    <div class="orb blue"></div>

    <main class="page">
        <section class="command-shell">
            <div class="panel login-panel">
                <div class="scanline"></div>

                <div>
                    <div class="brand-icon">🚑</div>
                    <div class="kicker">LSMD Access System</div>

                    <h1>LSMD<br>Abteilungs<br>Zentrale</h1>

                    <p>
                        Melde dich mit Discord an und verwalte Ausbildung, Overwatch,
                        Punkte, Dokumente und interne Abteilungssysteme zentral an einem Ort.
                    </p>

                    <% if (typeof error !== "undefined" && error) { %>
                        <p style="color:#fecaca;font-weight:900;"><%= error %></p>
                    <% } %>

                    <a href="/auth/discord" class="login-btn">
                        <span>💬</span>
                        Mit Discord einloggen
                    </a>

                    <div class="access-grid">
                        <div class="access-card">
                            <h3>Admin</h3>
                            <span>Voller Zugriff</span>
                        </div>

                        <div class="access-card">
                            <h3>Abteilungen</h3>
                            <span>Rollenbasierter Zugriff</span>
                        </div>
                    </div>
                </div>

                <div class="small-note">
                    Zugriff nur mit gültiger Discord-Rolle.
                </div>
            </div>

            <div class="panel hero-panel">
                <div class="scanline"></div>
                <div class="online">Online</div>

                <div class="kicker">Live System</div>

                <h1 class="hero-title">Abteilungen.<br>Systeme.<br>Kontrolle.</h1>

                <p>
                    Die LSMD Abteilungszentrale verbindet Discord-Login, Rollenprüfung,
                    Punkteverwaltung, Lizenzsysteme, Dokumente und interne Verwaltung
                    in einem modernen System.
                </p>

                <div class="feature-grid">
                    <div class="feature-card">
                        <div class="feature-icon">🏥</div>
                        <div>
                            <h3>Abteilungen</h3>
                            <p>Prakti/Sani, Overwatch und interne LSMD-Bereiche zentral verwalten.</p>
                        </div>
                    </div>

                    <div class="feature-card">
                        <div class="feature-icon">👁️</div>
                        <div>
                            <h3>Overwatch-System</h3>
                            <p>Lizenzen, Auffrischungen und Prüfer sauber dokumentieren.</p>
                        </div>
                    </div>

                    <div class="feature-card">
                        <div class="feature-icon">📄</div>
                        <div>
                            <h3>Dokumente</h3>
                            <p>Leitfäden, Regelwerke und Checklisten zentral abrufen.</p>
                        </div>
                    </div>

                    <div class="feature-card">
                        <div class="feature-icon">🛡️</div>
                        <div>
                            <h3>Admin Tools</h3>
                            <p>Interne Panels, Rechte und Systeme übersichtlich steuern.</p>
                        </div>
                    </div>
                </div>

                <div class="status-grid">
                    <div class="status-card">
                        <h3>Discord</h3>
                        <strong>Verbunden</strong>
                    </div>

                    <div class="status-card">
                        <h3>MongoDB</h3>
                        <strong>Online</strong>
                    </div>

                    <div class="status-card">
                        <h3>LSMD</h3>
                        <strong>Bereit</strong>
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>
</html>