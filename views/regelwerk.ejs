    <div class="card">
        <div class="card-header">
            <div>
                <h2>Allgemeines Verhalten</h2>
                <p class="card-subtitle">Respektvoller Umgang und klare Kommunikation</p>
            </div>
        </div>

        <div class="info-list">
            <div>
                <span>Umgang</span>
                <strong>Jeder wird respektvoll und sachlich behandelt</strong>
            </div>

            <div>
