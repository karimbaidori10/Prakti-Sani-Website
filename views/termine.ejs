<div class="page-header">
    <h1>📅 Termine</h1>
    <p>Prüfungstermine planen, verwalten und Status aktuell halten.</p>
</div>

<section class="card">
    <div class="card-header">
        <h2>🗓️ Kalenderübersicht</h2>
        <span class="chip blue">Monatsansicht</span>
    </div>

    <% 
        const today = new Date();
        const year = today.getFullYear();
        const month = today.getMonth();

        const monthName = today.toLocaleString("de-DE", { month: "long", year: "numeric" });

        const firstDay = new Date(year, month, 1);
        const lastDay = new Date(year, month + 1, 0);

        let startDay = firstDay.getDay();
        startDay = startDay === 0 ? 6 : startDay - 1;

        const daysInMonth = lastDay.getDate();
        const calendarDays = [];

        for (let i = 0; i < startDay; i++) {
            calendarDays.push(null);
        }

        for (let day = 1; day <= daysInMonth; day++) {
            calendarDays.push(day);
        }

        function getTermineForDay(day) {
            if (!day || !termine) return [];

            return termine.filter(t => {
                if (!t.date) return false;

                const d = new Date(t.date);
                return d.getFullYear() === year &&
                       d.getMonth() === month &&
                       d.getDate() === day;
            });
        }
    %>

    <div class="calendar-title">
        <h3><%= monthName %></h3>
    </div>

    <div class="calendar-grid calendar-head">
        <div>Mo</div>
        <div>Di</div>
        <div>Mi</div>
        <div>Do</div>
        <div>Fr</div>
        <div>Sa</div>
        <div>So</div>
    </div>

    <div class="calendar-grid">
        <% calendarDays.forEach(day => { %>
            <div class="calendar-day <%= day === today.getDate() ? 'today' : '' %>">
                <% if (day) { %>
                    <strong><%= day %></strong>

                    <% const dayTermine = getTermineForDay(day); %>

                    <% if (dayTermine.length > 0) { %>
                        <div class="calendar-events">
                            <% dayTermine.slice(0, 2).forEach(t => { %>
                                <div class="calendar-event <%= t.status === 'bestanden' ? 'success-event' : t.status === 'nicht bestanden' ? 'danger-event' : t.status === 'verschoben' ? 'warning-event' : 'blue-event' %>">
                                    <span><%= t.time || "--:--" %></span>
                                    <p><%= t.examType || "Termin" %></p>
                                </div>
                            <% }) %>

                            <% if (dayTermine.length > 2) { %>
                                <small>+ <%= dayTermine.length - 2 %> weitere</small>
                            <% } %>
                        </div>
                    <% } %>
                <% } %>
            </div>
        <% }) %>
    </div>
</section>

<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h2>➕ Neuen Termin erstellen</h2>
            <span class="chip blue">Planung</span>
        </div>

        <form method="POST" action="/termine/create" class="form">
            <input name="name" placeholder="Name des Teilnehmers" required>

            <input name="discordId" placeholder="Discord ID optional">

            <select name="examType" required>
                <option value="">Prüfungsart wählen</option>
                <option>Prakti-Prüfung</option>
                <option>Darf alleine fahren</option>
                <option>Sanitäter-Prüfung</option>
                <option>Theorie-Prüfung</option>
                <option>Regelwerk</option>
                <option>Blaues Blatt</option>
                <option>Funkleitfaden</option>
            </select>

            <div class="form-row">
                <input type="date" name="date" required>
                <input type="time" name="time" required>
            </div>

            <input name="examiner" placeholder="Prüfer / Ausbilder">

            <select name="status">
                <option value="offen">Offen</option>
                <option value="bestanden">Bestanden</option>
                <option value="nicht bestanden">Nicht bestanden</option>
                <option value="verschoben">Verschoben</option>
            </select>

            <textarea name="notes" placeholder="Notizen"></textarea>

            <button type="submit">Termin speichern</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>⚡ Termin-Status</h2>
            <span class="chip green">Live</span>
        </div>

        <div class="mini-stats">
            <div class="mini-stat">
                <strong><%= termine ? termine.length : 0 %></strong>
                <span>Gesamt</span>
            </div>

            <div class="mini-stat">
                <strong><%= termine ? termine.filter(t => t.status === "offen").length : 0 %></strong>
                <span>Offen</span>
            </div>

            <div class="mini-stat">
                <strong><%= termine ? termine.filter(t => t.status === "bestanden").length : 0 %></strong>
                <span>Bestanden</span>
            </div>

            <div class="mini-stat">
                <strong><%= termine ? termine.filter(t => t.status === "verschoben").length : 0 %></strong>
                <span>Verschoben</span>
            </div>
        </div>

        <div class="clean-divider"></div>

        <p style="color: var(--muted);">
            Tipp: Später bauen wir hier die Kalenderansicht ein, damit Termine direkt als Monatskalender angezeigt werden.
        </p>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2>📋 Terminübersicht</h2>
        <span class="chip blue"><%= termine ? termine.length : 0 %> Termine</span>
    </div>

    <% if (!termine || termine.length === 0) { %>
        <div class="empty-state">
            <div>📭</div>
            <h3>Keine Termine vorhanden</h3>
            <p>Erstelle links deinen ersten Prüfungstermin.</p>
        </div>
    <% } else { %>

        <div class="termine-list">
            <% termine.forEach(t => { %>
                <div class="termin-card">
                    <div class="date-box">
                        <strong><%= t.date ? new Date(t.date).getDate() : "--" %></strong>
                        <span>
                            <%= t.date ? new Date(t.date).toLocaleString("de-DE", { month: "short" }).toUpperCase() : "---" %>
                        </span>
                    </div>

                    <div class="termin-main">
                        <h3><%= t.examType %></h3>
                        <p>
                            👤 <%= t.name %>
                            <% if (t.discordId) { %>
                                · 🆔 <%= t.discordId %>
                            <% } %>
                        </p>

                        <p>
                            🕒 <%= t.time || "--:--" %> Uhr
                            · 🧑‍🏫 <%= t.examiner || "Kein Prüfer eingetragen" %>
                        </p>

                        <% if (t.notes) { %>
                            <p class="termin-note">📝 <%= t.notes %></p>
                        <% } %>
                    </div>

                    <div class="termin-status">
                        <% if (t.status === "bestanden") { %>
                            <span class="badge success">Bestanden</span>
                        <% } else if (t.status === "nicht bestanden") { %>
                            <span class="badge danger">Nicht bestanden</span>
                        <% } else if (t.status === "verschoben") { %>
                            <span class="badge warning">Verschoben</span>
                        <% } else { %>
                            <span class="badge warning">Offen</span>
                        <% } %>

                        <form method="POST" action="/termine/status/<%= t._id %>" class="mini-form">
                            <select name="status">
                                <option value="offen" <%= t.status === "offen" ? "selected" : "" %>>Offen</option>
                                <option value="bestanden" <%= t.status === "bestanden" ? "selected" : "" %>>Bestanden</option>
                                <option value="nicht bestanden" <%= t.status === "nicht bestanden" ? "selected" : "" %>>Nicht bestanden</option>
                                <option value="verschoben" <%= t.status === "verschoben" ? "selected" : "" %>>Verschoben</option>
                            </select>

                            <button type="submit">Ändern</button>
                        </form>

                        <% if (isAdmin) { %>
                            <form method="POST" action="/termine/delete/<%= t._id %>">
                                <button type="submit" class="danger-btn">Löschen</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

    <% } %>
</section>