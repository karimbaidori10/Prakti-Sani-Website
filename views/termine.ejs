<%
const allTermine = Array.isArray(termine) ? termine : [];

function formatDate(dateValue) {
    if (!dateValue) return "-";

    const date = new Date(dateValue + "T00:00:00");

    if (isNaN(date.getTime())) {
        return dateValue;
    }

    return date.toLocaleDateString("de-DE");
}

const saniCount = allTermine.filter(t => t.examType === "Sanitaeter-Pruefung").length;
const fahrCount = allTermine.filter(t => t.examType === "Darf alleine fahren").length;
%>

<section class="page-header sheet-hero">
    <div>
        <h1>Ausbildungstermine</h1>
        <p>Verwalte Sanitäter-Prüfungen und Fahrfreigaben.</p>
    </div>

    <div class="sheet-hero-count">
        <strong><%= allTermine.length %></strong>
        <span>Einträge</span>
    </div>
</section>

<section class="stats-grid">
    <div class="stat-card stat-blue">
        <div class="stat-icon">🚑</div>
        <div>
            <h2><%= saniCount %></h2>
            <p>Sanitäter-Prüfungen</p>
        </div>
    </div>

    <div class="stat-card stat-green">
        <div class="stat-icon">🚗</div>
        <div>
            <h2><%= fahrCount %></h2>
            <p>Fahrfreigaben</p>
        </div>
    </div>

    <div class="stat-card stat-yellow">
        <div class="stat-icon">📅</div>
        <div>
            <h2><%= allTermine.length %></h2>
            <p>Gesamt</p>
        </div>
    </div>

    <div class="stat-card stat-red">
        <div class="stat-icon">⚡</div>
        <div>
            <h2>Live</h2>
            <p>Status</p>
        </div>
    </div>
</section>

<section class="sheet-layout">
    <div class="card clean-panel">
        <div class="card-header">
            <div>
                <h2>Einträge</h2>
                <p class="card-subtitle">Alle geplanten Ausbildungstermine.</p>
            </div>

            <span class="chip blue"><%= allTermine.length %> Termine</span>
        </div>

        <% if (allTermine.length > 0) { %>
            <div class="pro-searchbar">
                <input
                    type="text"
                    id="terminSearch"
                    placeholder="Eintrag suchen..."
                    autocomplete="off"
                >

                <select id="terminFilter">
                    <option value="all">Alle Arten</option>
                    <option value="sani">Sanitäter-Prüfung</option>
                    <option value="fahr">Fahrfreigabe</option>
                </select>
            </div>
        <% } %>

        <% if (allTermine.length === 0) { %>
            <div class="empty-state">
                <div>📅</div>
                <h3>Keine Termine vorhanden</h3>
                <p>Erstelle rechts einen neuen Ausbildungstermin.</p>
            </div>
        <% } else { %>
            <div class="training-board">
                <% allTermine.forEach((termin, index) => { %>
                    <div
                        class="training-entry termin-filter-row"
                        data-search="<%= [
                            termin.name || '',
                            termin.examType || '',
                            termin.date || '',
                            termin.time || '',
                            termin.examiner || '',
                            termin.notes || ''
                        ].join(' ').toLowerCase() %>"
                        data-type="<%= termin.examType === 'Darf alleine fahren' ? 'fahr' : 'sani' %>"
                    >
                        <div class="training-number">
                            <span>#</span>
                            <strong><%= index + 1 %></strong>
                        </div>

                        <div class="training-date-box">
                            <span>Datum</span>
                            <strong><%= formatDate(termin.date) %></strong>
                            <small><%= termin.time || "-" %></small>
                        </div>

                        <div class="training-content">
                            <div class="training-topline">
                                <h3><%= termin.name || "Unbekannt" %></h3>

                                <% if (termin.examType === "Darf alleine fahren") { %>
                                    <span class="badge blue">Fahrfreigabe</span>
                                <% } else { %>
                                    <span class="badge success">Sanitäter-Prüfung</span>
                                <% } %>
                            </div>

                            <div class="training-info-grid">
                                <div>
                                    <span>Art</span>
                                    <strong>
                                        <%= termin.examType === "Sanitaeter-Pruefung" ? "Sanitäter-Prüfung" : termin.examType %>
                                    </strong>
                                </div>

                                <div>
                                    <span>Ausbilder / Prüfer</span>
                                    <strong><%= termin.examiner || "-" %></strong>
                                </div>

                                <div>
                                    <span>Status</span>
                                    <strong><%= termin.status || "Offen" %></strong>
                                </div>

                                <div>
                                    <span>Quelle</span>
                                    <strong><%= termin.source || "Website" %></strong>
                                </div>
                            </div>

                            <% if (termin.notes) { %>
                                <div class="training-note-box">
                                    <span>Notiz</span>
                                    <p><%= termin.notes %></p>
                                </div>
                            <% } %>
                        </div>

                        <% if (isAdmin) { %>
                            <div class="training-actions">
                                <a class="mini-btn" href="/termine/edit/<%= termin._id %>">Bearbeiten</a>

                                <form method="POST" action="/termine/delete/<%= termin._id %>">
                                    <button class="danger-btn" type="submit">Löschen</button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <% if (isAdmin) { %>
        <aside class="card clean-panel training-doc-side">
            <div class="card-header">
                <div>
                    <h2>Neuer Termin</h2>
                    <p class="card-subtitle">Ausbildungstermin erstellen.</p>
                </div>
            </div>

            <form class="form" method="POST" action="/termine/create">
                <input type="text" name="name" placeholder="Name / Teilnehmer" required>

                <select name="examType" required>
                    <option value="Sanitaeter-Pruefung">Sanitäter-Prüfung</option>
                    <option value="Darf alleine fahren">Fahrfreigabe</option>
                </select>

                <input type="date" name="date" required>
                <input type="time" name="time">
                <input type="text" name="examiner" placeholder="Ausbilder / Prüfer" required>

                <textarea name="notes" placeholder="Notiz optional"></textarea>

                <button type="submit">Termin erstellen</button>
            </form>
        </aside>
    <% } %>
</section>

<script>
    const terminSearch = document.getElementById("terminSearch");
    const terminFilter = document.getElementById("terminFilter");
    const terminRows = Array.from(document.querySelectorAll(".termin-filter-row"));

    function filterTermine() {
        const query = (terminSearch?.value || "").toLowerCase().trim();
        const filter = terminFilter?.value || "all";

        terminRows.forEach(row => {
            const searchText = row.dataset.search || "";
            const type = row.dataset.type || "";

            const matchesSearch = searchText.includes(query);
            const matchesFilter = filter === "all" || type === filter;

            row.style.display = matchesSearch && matchesFilter ? "" : "none";
        });
    }

    if (terminSearch) {
        terminSearch.addEventListener("input", filterTermine);
    }

    if (terminFilter) {
        terminFilter.addEventListener("change", filterTermine);
    }
</script>
