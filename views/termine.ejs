<div class="page-header">
    <h1>Ausbildungstermine</h1>
    <p>Automatisch dokumentierte Sanit&auml;ter-Pr&uuml;fungen mit Datum, Uhrzeit, Ausbilder und Status.</p>
</div>

<section class="stats-grid">
    <div class="stat-card stat-blue">
        <div class="stat-icon">AZ</div>
        <div>
            <h2><%= termine ? termine.length : 0 %></h2>
            <strong>Eintr&auml;ge</strong>
            <p>Dokumentierte Termine</p>
        </div>
    </div>

    <div class="stat-card stat-green">
        <div class="stat-icon">OK</div>
        <div>
            <h2><%= termine ? termine.filter(t => t.status === "Bestanden").length : 0 %></h2>
            <strong>Bestanden</strong>
            <p>Erfolgreiche Pr&uuml;fungen</p>
        </div>
    </div>

    <div class="stat-card stat-red">
        <div class="stat-icon">NO</div>
        <div>
            <h2><%= termine ? termine.filter(t => t.status === "Nicht bestanden").length : 0 %></h2>
            <strong>Nicht bestanden</strong>
            <p>Dokumentierte Fehlversuche</p>
        </div>
    </div>

    <div class="stat-card stat-yellow">
        <div class="stat-icon">OF</div>
        <div>
            <h2><%= termine ? termine.filter(t => !t.status || t.status === "Offen" || t.status === "Teilgenommen").length : 0 %></h2>
            <strong>Offen</strong>
            <p>Noch offen / teilgenommen</p>
        </div>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2>Ausbildungsdokumentation</h2>
        <span class="chip blue"><%= termine ? termine.length : 0 %> Eintr&auml;ge</span>
    </div>

    <% if (!termine || termine.length === 0) { %>
        <div class="empty-state">
            <div>Keine Daten</div>
            <h3>Keine Ausbildungstermine vorhanden</h3>
            <p>Neue Eintr&auml;ge entstehen automatisch, sobald eine Sanit&auml;ter-Pr&uuml;fung eingetragen wird.</p>
        </div>
    <% } else { %>

        <div class="training-list">
            <% termine.forEach((termin) => { %>
                <div class="training-card">
                    <div class="training-date">
                        <span class="training-label">Datum</span>
                        <strong><%= termin.date || "-" %></strong>
                        <span><%= termin.time || "--:--" %> Uhr</span>
                    </div>

                    <div class="training-main">
                        <div class="training-title-row">
                            <h3><%= termin.name || "Unbekannt" %></h3>
                            <span class="chip blue">Sanit&auml;ter-Pr&uuml;fung</span>
                        </div>

                        <div class="training-meta">
                            <p><strong>Ausbilder:</strong> <%= termin.examiner || "-" %></p>
                            <p><strong>Discord ID:</strong> <%= termin.discordId || "-" %></p>
                            <p><strong>Eintrag:</strong> Automatisch aus Pr&uuml;fungen</p>
                        </div>

                        <% if (termin.notes) { %>
                            <p class="training-note"><strong>Notiz:</strong> <%= termin.notes %></p>
                        <% } %>
                    </div>

                    <div class="training-status">
                        <% if (termin.status === "Bestanden") { %>
                            <span class="badge success">Bestanden</span>
                        <% } else if (termin.status === "Nicht bestanden") { %>
                            <span class="badge danger">Nicht bestanden</span>
                        <% } else if (termin.status === "Teilgenommen") { %>
                            <span class="badge blue">Teilgenommen</span>
                        <% } else { %>
                            <span class="badge warning"><%= termin.status || "Offen" %></span>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

    <% } %>
</section>