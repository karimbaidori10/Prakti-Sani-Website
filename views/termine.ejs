<style>
/* =====================================================
   LSMD AUSBILDUNGSTERMINE — MISSION CONTROL DESIGN
   Direkt in views/termine.ejs einfügen
===================================================== */

:root {
    --mc-bg: #020617;
    --mc-panel: rgba(8, 13, 28, 0.92);
    --mc-panel-2: rgba(15, 23, 42, 0.86);
    --mc-line: rgba(125, 211, 252, 0.18);
    --mc-line-soft: rgba(148, 163, 184, 0.14);
    --mc-blue: #2563eb;
    --mc-cyan: #06b6d4;
    --mc-red: #ef233c;
    --mc-pink: #db2777;
    --mc-green: #22c55e;
    --mc-yellow: #facc15;
    --mc-text: #f8fafc;
    --mc-muted: rgba(226, 232, 240, 0.65);
}

/* Seite */
body {
    background:
        radial-gradient(circle at 0% 0%, rgba(239, 35, 60, 0.18), transparent 30%),
        radial-gradient(circle at 100% 0%, rgba(37, 99, 235, 0.26), transparent 34%),
        linear-gradient(135deg, #020617 0%, #050816 48%, #020617 100%) !important;
}

/* feines Raster, nicht animiert = kein Lag */
body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 44px 44px;
    opacity: 0.55;
    z-index: 0;
}

main,
.content,
.main-content,
.dashboard-content,
.page-content {
    position: relative !important;
    z-index: 1 !important;
    max-width: 1320px !important;
    margin: 0 auto !important;
    padding: 18px 22px 46px !important;
}

/* ===========================
   HERO — Mission Header
=========================== */

section:first-of-type {
    position: relative !important;
    overflow: hidden !important;
    padding: 30px 34px !important;
    border-radius: 30px !important;
    background:
        linear-gradient(135deg, rgba(239, 35, 60, 0.17), rgba(37, 99, 235, 0.16)),
        rgba(8, 13, 28, 0.92) !important;
    border: 1px solid rgba(125, 211, 252, 0.22) !important;
    box-shadow:
        0 24px 70px rgba(0, 0, 0, 0.42),
        inset 0 1px 0 rgba(255,255,255,0.05) !important;
}

section:first-of-type::before {
    content: "LSMD TRAINING CONTROL";
    position: absolute;
    right: 34px;
    top: 26px;
    padding: 8px 13px;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.28);
    color: #bbf7d0;
    font-size: 11px;
    font-weight: 1000;
    letter-spacing: 0.14em;
}

section:first-of-type::after {
    content: "";
    position: absolute;
    right: -80px;
    bottom: -90px;
    width: 330px;
    height: 330px;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.20);
    filter: blur(26px);
    pointer-events: none;
}

section:first-of-type h1 {
    position: relative !important;
    z-index: 2 !important;
    width: fit-content;
    margin: 0 0 10px !important;
    font-size: clamp(42px, 5vw, 68px) !important;
    line-height: 0.92 !important;
    letter-spacing: -0.07em !important;
    color: #fff !important;
    text-shadow: 0 18px 45px rgba(0,0,0,0.35) !important;
}

section:first-of-type h1::after {
    content: "";
    display: block;
    width: 88px;
    height: 4px;
    margin-top: 16px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--mc-red), var(--mc-blue), var(--mc-cyan));
}

section:first-of-type p {
    position: relative !important;
    z-index: 2 !important;
    max-width: 760px !important;
    color: var(--mc-muted) !important;
    font-size: 15px !important;
    line-height: 1.55 !important;
}

/* Hero Counter rechts */
section:first-of-type div:last-child,
section:first-of-type .hero-count,
section:first-of-type .counter-card {
    position: relative !important;
    z-index: 2 !important;
    border-radius: 22px !important;
    background: rgba(37, 99, 235, 0.20) !important;
    border: 1px solid rgba(125, 211, 252, 0.26) !important;
    box-shadow: 0 18px 40px rgba(37, 99, 235, 0.22) !important;
}

/* ===========================
   CREATE FORM — Command Card
=========================== */

section:has(form[action="/termine/create"]) {
    position: relative !important;
    overflow: hidden !important;
    margin-top: 18px !important;
    padding: 0 !important;
    border-radius: 30px !important;
    background: rgba(8, 13, 28, 0.94) !important;
    border: 1px solid rgba(125, 211, 252, 0.20) !important;
    box-shadow:
        0 24px 70px rgba(0,0,0,0.38),
        inset 0 1px 0 rgba(255,255,255,0.04) !important;
}

section:has(form[action="/termine/create"])::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: linear-gradient(90deg, var(--mc-red), var(--mc-blue), var(--mc-cyan));
}

section:has(form[action="/termine/create"]) > * {
    position: relative;
    z-index: 2;
}

section:has(form[action="/termine/create"]) h2 {
    margin: 0 !important;
    padding: 26px 28px 4px !important;
    font-size: 26px !important;
    line-height: 1 !important;
    color: #fff !important;
    letter-spacing: -0.04em !important;
}

section:has(form[action="/termine/create"]) h2::before {
    content: "✦";
    margin-right: 10px;
    color: var(--mc-cyan);
}

section:has(form[action="/termine/create"]) p {
    margin: 0 !important;
    padding: 0 28px 20px !important;
    color: var(--mc-muted) !important;
    font-size: 13px !important;
}

form[action="/termine/create"] {
    display: grid !important;
    grid-template-columns: 1.2fr 0.95fr 0.8fr 0.7fr 0.65fr !important;
    gap: 12px !important;
    align-items: stretch !important;
    padding: 22px 28px 28px !important;
    border-top: 1px solid rgba(148, 163, 184, 0.12) !important;
}

/* Inputs */
form[action="/termine/create"] input,
form[action="/termine/create"] select,
form[action="/termine/create"] textarea {
    width: 100% !important;
    height: 50px !important;
    border-radius: 15px !important;
    border: 1px solid rgba(148, 163, 184, 0.16) !important;
    background:
        linear-gradient(180deg, rgba(2, 6, 23, 0.88), rgba(2, 6, 23, 0.72)) !important;
    color: #f8fafc !important;
    padding: 0 15px !important;
    font-size: 13px !important;
    font-weight: 850 !important;
    outline: none !important;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.035),
        0 10px 24px rgba(0,0,0,0.16) !important;
}

form[action="/termine/create"] input::placeholder,
form[action="/termine/create"] textarea::placeholder {
    color: rgba(226, 232, 240, 0.42) !important;
}

form[action="/termine/create"] input:focus,
form[action="/termine/create"] select:focus,
form[action="/termine/create"] textarea:focus {
    border-color: rgba(34, 211, 238, 0.82) !important;
    box-shadow:
        0 0 0 3px rgba(6, 182, 212, 0.14),
        0 14px 34px rgba(6, 182, 212, 0.10) !important;
}

/* Selects wirken wie Command Dropdowns */
form[action="/termine/create"] select {
    cursor: pointer !important;
    appearance: auto !important;
}

/* Datum / Uhrzeit */
form[action="/termine/create"] input[type="date"],
form[action="/termine/create"] input[type="time"] {
    text-align: center !important;
}

/* Prüfer */
form[action="/termine/create"] select[name="examiner"] {
    grid-column: span 2 !important;
}

/* Notiz */
form[action="/termine/create"] textarea {
    grid-column: span 4 !important;
    height: 76px !important;
    min-height: 76px !important;
    padding: 15px !important;
    resize: vertical !important;
}

/* Button */
form[action="/termine/create"] button {
    grid-row: span 2 !important;
    min-height: 76px !important;
    border: none !important;
    border-radius: 19px !important;
    cursor: pointer !important;
    color: white !important;
    font-size: 17px !important;
    line-height: 1.12 !important;
    font-weight: 1000 !important;
    background:
        linear-gradient(135deg, #2563eb 0%, #06b6d4 100%) !important;
    box-shadow:
        0 20px 44px rgba(37, 99, 235, 0.34),
        inset 0 1px 0 rgba(255,255,255,0.18) !important;
    transition: transform 0.16s ease, filter 0.16s ease !important;
}

form[action="/termine/create"] button:hover {
    transform: translateY(-2px) !important;
    filter: brightness(1.08) !important;
}

/* ===========================
   STATS — Command Tiles
=========================== */

.stats-grid,
.termine-stats,
.ausbildung-stats,
section:has(form[action="/termine/create"]) + div {
    display: grid !important;
    grid-template-columns: repeat(4, 1fr) !important;
    gap: 14px !important;
    margin-top: 20px !important;
}

.stat-card,
.termine-stat-card,
.ausbildung-stat-card,
section:has(form[action="/termine/create"]) + div > * {
    position: relative !important;
    overflow: hidden !important;
    min-height: 112px !important;
    padding: 18px !important;
    border-radius: 22px !important;
    background:
        radial-gradient(circle at 10% 10%, rgba(37, 99, 235, 0.15), transparent 38%),
        rgba(15, 23, 42, 0.82) !important;
    border: 1px solid rgba(148, 163, 184, 0.14) !important;
    box-shadow: 0 16px 42px rgba(0,0,0,0.24) !important;
}

.stat-card::before,
.termine-stat-card::before,
.ausbildung-stat-card::before,
section:has(form[action="/termine/create"]) + div > *::before {
    content: "";
    position: absolute;
    left: 0;
    top: 18px;
    bottom: 18px;
    width: 4px;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--mc-blue), var(--mc-cyan));
}

.stat-card h2,
.termine-stat-card h2,
.ausbildung-stat-card h2,
section:has(form[action="/termine/create"]) + div h2 {
    margin: 0 !important;
    font-size: 34px !important;
    line-height: 1 !important;
    color: #fff !important;
}

.stat-card p,
.termine-stat-card p,
.ausbildung-stat-card p,
section:has(form[action="/termine/create"]) + div p {
    color: var(--mc-muted) !important;
    margin: 5px 0 0 !important;
}

/* ===========================
   UNTEN — Wochen-Doku/Ausbilder Panels
=========================== */

section:not(:first-of-type):not(:has(form[action="/termine/create"])) {
    border-radius: 26px !important;
}

section:not(:first-of-type):not(:has(form[action="/termine/create"])) article,
section:not(:first-of-type):not(:has(form[action="/termine/create"])) .card,
.wochen-doku,
.week-card,
.ausbilder-card,
.termine-list-card {
    border-radius: 24px !important;
    background:
        linear-gradient(145deg, rgba(15, 23, 42, 0.88), rgba(2, 6, 23, 0.74)) !important;
    border: 1px solid rgba(148, 163, 184, 0.15) !important;
    box-shadow: 0 18px 45px rgba(0,0,0,0.26) !important;
}

h2, h3 {
    color: #fff !important;
}

/* kleine Premium-Linie unter Überschriften */
h2::after {
    content: "";
    display: block;
    width: 48px;
    height: 3px;
    margin-top: 9px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--mc-blue), var(--mc-red));
}

/* ===========================
   RESPONSIVE
=========================== */

@media (max-width: 1100px) {
    form[action="/termine/create"] {
        grid-template-columns: 1fr 1fr !important;
    }

    form[action="/termine/create"] textarea,
    form[action="/termine/create"] button,
    form[action="/termine/create"] select[name="examiner"] {
        grid-column: span 2 !important;
    }

    .stats-grid,
    .termine-stats,
    .ausbildung-stats,
    section:has(form[action="/termine/create"]) + div {
        grid-template-columns: repeat(2, 1fr) !important;
    }
}

@media (max-width: 650px) {
    main,
    .content,
    .main-content,
    .dashboard-content,
    .page-content {
        padding: 12px !important;
    }

    section:first-of-type,
    section:has(form[action="/termine/create"]) {
        border-radius: 22px !important;
    }

    section:first-of-type {
        padding: 24px !important;
    }

    section:first-of-type::before {
        position: static;
        display: inline-flex;
        margin-bottom: 14px;
    }

    section:first-of-type h1 {
        font-size: 38px !important;
    }

    form[action="/termine/create"] {
        grid-template-columns: 1fr !important;
        padding: 18px !important;
    }

    form[action="/termine/create"] textarea,
    form[action="/termine/create"] button,
    form[action="/termine/create"] select[name="examiner"] {
        grid-column: span 1 !important;
    }

    .stats-grid,
    .termine-stats,
    .ausbildung-stats,
    section:has(form[action="/termine/create"]) + div {
        grid-template-columns: 1fr !important;
    }
}
</style>

<%
    const allTermine = termine || [];

    function parseDate(value) {
        if (!value) return null;
        return new Date(value + "T00:00:00");
    }

    function getWeekNumber(date) {
        if (!date || isNaN(date)) return "-";
        const tempDate = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
        const dayNum = tempDate.getUTCDay() || 7;
        tempDate.setUTCDate(tempDate.getUTCDate() + 4 - dayNum);
        const yearStart = new Date(Date.UTC(tempDate.getUTCFullYear(), 0, 1));
        return Math.ceil((((tempDate - yearStart) / 86400000) + 1) / 7);
    }

    function formatDate(value) {
        const date = parseDate(value);
        if (!date || isNaN(date)) return "-";

        const day = String(date.getDate()).padStart(2, "0");
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const year = date.getFullYear();

        return day + "." + month + "." + year;
    }

    function getDayName(value) {
        const date = parseDate(value);
        if (!date || isNaN(date)) return "-";

        const days = ["Sonntag", "Montag", "Dienstag", "Mittwoch", "Donnerstag", "Freitag", "Samstag"];
        return days[date.getDay()];
    }

    const groupedWeeks = {};

    allTermine.forEach((item) => {
        const itemDate = parseDate(item.date);
        const year = itemDate && !isNaN(itemDate) ? itemDate.getFullYear() : "Unbekannt";
        const week = "KW " + getWeekNumber(itemDate) + " / " + year;

        if (!groupedWeeks[week]) {
            groupedWeeks[week] = [];
        }

        groupedWeeks[week].push(item);
    });

    const weekKeys = Object.keys(groupedWeeks);

    const ausbilderStats = {};

    allTermine.forEach((item) => {
        const name = item.examiner || "Nicht eingetragen";

        if (!ausbilderStats[name]) {
            ausbilderStats[name] = 0;
        }

        ausbilderStats[name]++;
    });

    const ausbilderList = Object.entries(ausbilderStats);

    const saniCount = allTermine.filter(t => t.examType === "Sanitaeter-Pruefung").length;
    const fahrCount = allTermine.filter(t => t.examType === "Darf alleine fahren").length;
%>

<div class="page-header sheet-hero">
    <div>
        <h1>Ausbildungstermine</h1>
        <p>MD-System f&uuml;r Fahrfreigaben, Sanit&auml;ter-Pr&uuml;fungen und Ausbildungsdokumentation.</p>
    </div>

    <div class="sheet-hero-count">
        <strong><%= allTermine.length %></strong>
        <span>Eintr&auml;ge</span>
    </div>
</div>

<% if (isAdmin || (user && user.role === "Prakti-Sani")) { %>
<section class="card md-small-entry-card admin-glow">
    <div class="card-header">
        <div>
            <h2>Neuen Eintrag erstellen</h2>
            <p class="card-subtitle">Schnell-Eingabe f&uuml;r Ausbilder und Leitung.</p>
        </div>

        <span class="chip blue">Eintragen</span>
    </div>

    <form method="POST" action="/termine/create" class="md-small-form">
        <input name="name" placeholder="Name des Teilnehmers" required>

        <select name="examType" required>
    <option value="">Art wählen</option>
    <option value="Sanitaeter-Pruefung">Sanitäter-Prüfung</option>
</select>

<select name="result" required>
    <option value="">Ergebnis wählen</option>
    <option value="bestanden">Bestanden</option>
    <option value="nicht_bestanden">Nicht bestanden</option>
</select>

        <input type="date" name="date" required>
        <input type="time" name="time">

        <select name="examiner" required>
    <option value="">Ausbilder / Pr&uuml;fer w&auml;hlen</option>

    <% if (typeof ausbilderOptions !== "undefined" && ausbilderOptions.length > 0) { %>
        <% ausbilderOptions.forEach((member) => { %>
            <option value="<%= member.name %>"><%= member.name %></option>
        <% }) %>
    <% } else { %>
        <option value="" disabled>Keine Ausbilder gefunden</option>
    <% } %>
</select>

        <textarea name="notes" placeholder="Notiz optional"></textarea>

        <button type="submit">Eintrag speichern</button>
    </form>
</section>
<% } %>

<section class="stats-grid">
    <div class="stat-card stat-blue">
        <div class="stat-icon">📋</div>
        <div>
            <h2><%= allTermine.length %></h2>
            <strong>Gesamt</strong>
            <p>Dokumentierte Eintr&auml;ge</p>
        </div>
    </div>

    <div class="stat-card stat-green">
        <div class="stat-icon">🚑</div>
        <div>
            <h2><%= saniCount %></h2>
            <strong>Sanit&auml;ter</strong>
            <p>Sanit&auml;ter-Pr&uuml;fungen</p>
        </div>
    </div>

    <div class="stat-card stat-yellow">
        <div class="stat-icon">🚗</div>
        <div>
            <h2><%= fahrCount %></h2>
            <strong>Fahrfreigaben</strong>
            <p>Darf alleine fahren</p>
        </div>
    </div>

    <div class="stat-card stat-red">
        <div class="stat-icon">👨‍🏫</div>
        <div>
            <h2><%= ausbilderList.length %></h2>
            <strong>Ausbilder</strong>
            <p>Aktive Ausbilder</p>
        </div>
    </div>
</section>

<section class="sheet-layout">
    <div class="card sheet-main">
        <div class="card-header">
            <div>
                <h2>Wochen-Dokumentation</h2>
                <p class="card-subtitle">Alle Eintr&auml;ge werden automatisch nach Kalenderwoche sortiert.</p>
            </div>

            <span class="chip blue"><%= allTermine.length %> Eintr&auml;ge</span>
        </div>

        <% if (allTermine.length === 0) { %>
            <div class="empty-state">
                <div>📅</div>
                <h3>Keine Ausbildungstermine vorhanden</h3>
                <p>Trage oben den ersten Eintrag ein.</p>
            </div>
        <% } else { %>

            <div class="sheet-week-list">
                <% weekKeys.forEach((week) => { %>
                    <div class="sheet-week-card">
                        <div class="sheet-week-header">
                            <h3><%= week %></h3>
                            <span><%= groupedWeeks[week].length %> Eintrag(e)</span>
                        </div>

                        <div class="sheet-table">
                            <div class="sheet-table-head sheet-table-head-clean">
                                <span>Wochentag</span>
                                <span>Datum</span>
                                <span>Uhrzeit</span>
                                <span>Teilnehmer</span>
                                <span>Ausbilder</span>
                                <span>Art</span>
                            </div>

                            <% groupedWeeks[week].forEach((termin) => { %>
                                <div class="sheet-table-row sheet-table-row-clean">
                                    <div>
                                        <small>Wochentag</small>
                                        <strong><%= getDayName(termin.date) %></strong>
                                    </div>

                                    <div>
                                        <small>Datum</small>
                                        <strong><%= formatDate(termin.date) %></strong>
                                    </div>

                                    <div>
                                        <small>Uhrzeit</small>
                                        <strong><%= termin.time || "--:--" %></strong>
                                    </div>

                                    <div>
                                        <small>Teilnehmer</small>
                                        <strong><%= termin.name || "Unbekannt" %></strong>
                                    </div>

                                    <div>
                                        <small>Ausbilder</small>
                                        <strong><%= termin.examiner || "-" %></strong>
                                    </div>

                                    <div>
                                        <small>Art</small>
                                        <% if (termin.examType === "Darf alleine fahren") { %>
                                            <span class="badge blue">Fahrfreigabe</span>
                                        <% } else { %>
                                            <span class="badge success">Sanit&auml;ter</span>
                                        <% } %>
                                    </div>

                                    <% if (termin.notes) { %>
                                        <div class="sheet-note">
                                            <small>Notiz</small>
                                            <p><%= termin.notes %></p>
                                        </div>
                                    <% } %>

                                    <% if (isAdmin) { %>
                                        <div class="sheet-actions">
                                            <a href="/termine/edit/<%= termin._id %>" class="open-doc-btn">
                                                Bearbeiten
                                            </a>

                                            <form method="POST" action="/termine/delete/<%= termin._id %>">
                                                <button type="submit" class="danger-btn" onclick="return confirm('Eintrag wirklich l&ouml;schen?');">
                                                    L&ouml;schen
                                                </button>
                                            </form>
                                        </div>
                                    <% } %>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                <% }) %>
            </div>

        <% } %>
    </div>

    <div class="card sheet-side">
        <div class="card-header">
            <div>
                <h2>Ausbilder</h2>
                <p class="card-subtitle">Eintr&auml;ge nach Ausbilder.</p>
            </div>
            <span class="chip green">Team</span>
        </div>

        <% if (ausbilderList.length === 0) { %>
            <div class="empty-state">
                <div>👨‍🏫</div>
                <h3>Keine Ausbilder vorhanden</h3>
                <p>Sobald Eintr&auml;ge erstellt werden, erscheint hier die Ausbilder-&Uuml;bersicht.</p>
            </div>
        <% } else { %>
            <div class="trainer-list">
                <% ausbilderList.forEach(([name, count]) => { %>
                    <div class="trainer-row">
                        <div class="trainer-avatar">
                            <%= name.charAt(0).toUpperCase() %>
                        </div>

                        <div>
                            <strong><%= name %></strong>
                            <span><%= count %> Eintrag(e)</span>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <div class="clean-divider"></div>

        <div class="sheet-help">
            <h3>System</h3>
            <p>Pr&uuml;fungen wurden entfernt. Alles wird direkt hier bei Ausbildungstermine eingetragen.</p>
        </div>

        <div class="clean-divider"></div>

