<div class="page-header">
    <h1>📅 Termine</h1>
    <p>Prüfungstermine planen, verwalten und Status aktuell halten.</p>
</div>

<section class="card">
    <div class="card-header">
        <h2>📋 Terminübersicht</h2>
        <span class="chip blue"><%= termine ? termine.length : 0 %> Termine</span>
    </div>

    <% if (!termine || termine.length === 0) { %>
        <div class="empty-state">
            <div>📭</div>
            <h3>Keine Termine vorhanden</h3>
            <p>Erstelle links deinen ersten Prüfungstermin.</p>
        </div>
    <% } else { %>

        <div class="termine-list">
            <% termine.forEach(t => { %>
                <div class="termin-card">
                    <div class="date-box">
                        <strong><%= t.date ? new Date(t.date).getDate() : "--" %></strong>
                        <span>
                            <%= t.date ? new Date(t.date).toLocaleString("de-DE", { month: "short" }).toUpperCase() : "---" %>
                        </span>
                    </div>

                    <div class="termin-main">
                        <h3><%= t.examType %></h3>
                        <p>
                            👤 <%= t.name %>
                            <% if (t.discordId) { %>
                                · 🆔 <%= t.discordId %>
                            <% } %>
                        </p>

                        <p>
                            🕒 <%= t.time || "--:--" %> Uhr
                            · 🧑‍🏫 <%= t.examiner || "Kein Prüfer eingetragen" %>
                        </p>

                        <% if (t.notes) { %>
                            <p class="termin-note">📝 <%= t.notes %></p>
                        <% } %>
                    </div>

                    <div class="termin-status">
                        <% if (t.status === "bestanden") { %>
                            <span class="badge success">Bestanden</span>
                        <% } else if (t.status === "nicht bestanden") { %>
                            <span class="badge danger">Nicht bestanden</span>
                        <% } else if (t.status === "verschoben") { %>
                            <span class="badge warning">Verschoben</span>
                        <% } else { %>
                            <span class="badge warning">Offen</span>
                        <% } %>

                        <form method="POST" action="/termine/status/<%= t._id %>" class="mini-form">
                            <select name="status">
                                <option value="offen" <%= t.status === "offen" ? "selected" : "" %>>Offen</option>
                                <option value="bestanden" <%= t.status === "bestanden" ? "selected" : "" %>>Bestanden</option>
                                <option value="nicht bestanden" <%= t.status === "nicht bestanden" ? "selected" : "" %>>Nicht bestanden</option>
                                <option value="verschoben" <%= t.status === "verschoben" ? "selected" : "" %>>Verschoben</option>
                            </select>

                            <button type="submit">Ändern</button>
                        </form>

                        <% if (isAdmin) { %>
                            <form method="POST" action="/termine/delete/<%= t._id %>">
                                <button type="submit" class="danger-btn">Löschen</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

    <% } %>
</section>