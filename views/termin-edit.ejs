<div class="page-header sheet-hero">
    <div>
        <h1>Eintrag bearbeiten</h1>
        <p>Bearbeite Teilnehmer, Art, Datum, Uhrzeit, Ausbilder und Notizen.</p>
    </div>

    <div class="sheet-hero-count">
        <strong>MD</strong>
        <span>Eintrag</span>
    </div>
</div>

<section class="edit-page-layout">
    <div class="card admin-glow edit-main-card">
        <div class="card-header">
            <div>
                <h2>Ausbildungstermin</h2>
                <p class="card-subtitle">Passe die Daten des bestehenden Eintrags an.</p>
            </div>

            <span class="chip blue">Bearbeiten</span>
        </div>

        <form method="POST" action="/termine/edit/<%= termin._id %>" class="form edit-form">
            <label>
                <span>Teilnehmer</span>
                <input name="name" value="<%= termin.name || '' %>" placeholder="Name des Teilnehmers" required>
            </label>

            <label>
                <span>Art</span>
                <select name="examType" required>
                    <option value="">Art w&auml;hlen</option>

                    <option value="Darf alleine fahren" <%= termin.examType === "Darf alleine fahren" ? "selected" : "" %>>
                        Darf alleine fahren
                    </option>

                    <option value="Sanitaeter-Pruefung" <%= termin.examType === "Sanitaeter-Pruefung" ? "selected" : "" %>>
                        Sanit&auml;ter-Pr&uuml;fung
                    </option>
                </select>
            </label>

            <div class="form-row">
                <label>
                    <span>Datum</span>
                    <input type="date" name="date" value="<%= termin.date || '' %>" required>
                </label>

                <label>
                    <span>Uhrzeit</span>
                    <input type="time" name="time" value="<%= termin.time || '' %>">
                </label>
            </div>

            <label>
                <span>Ausbilder / Pr&uuml;fer</span>
                <input name="examiner" value="<%= termin.examiner || '' %>" placeholder="Ausbilder / Pr&uuml;fer" required>
            </label>

            <label>
                <span>Notizen</span>
                <textarea name="notes" placeholder="Notizen"><%= termin.notes || '' %></textarea>
            </label>

            <div class="edit-actions">
                <button type="submit">Änderungen speichern</button>

                <a href="/termine" class="open-doc-btn">
                    Zur&uuml;ck
                </a>
            </div>
        </form>
    </div>

    <div class="card clean-panel edit-side-card">
        <div class="card-header">
            <div>
                <h2>Status</h2>
                <p class="card-subtitle">Aktueller Eintrag.</p>
            </div>

            <span class="chip green">Aktiv</span>
        </div>

        <div class="clean-status-list">
            <div>
                <span>Teilnehmer</span>
                <strong><%= termin.name || "Unbekannt" %></strong>
            </div>

            <div>
                <span>Art</span>
                <strong>
                    <% if (termin.examType === "Darf alleine fahren") { %>
                        Fahrfreigabe
                    <% } else { %>
                        Sanit&auml;ter
                    <% } %>
                </strong>
            </div>

            <div>
                <span>Datum</span>
                <strong><%= termin.date || "-" %></strong>
            </div>

            <div>
                <span>Ausbilder</span>
                <strong><%= termin.examiner || "-" %></strong>
            </div>
        </div>
    </div>
</section>