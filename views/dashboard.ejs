<%
    const allUsers = users || [];
    const latestTermine = termine || [];
    const termineAll = allTermine || [];
    const docsAll = docs || [];

    const displayName = typeof mdName !== "undefined" ? mdName : (user && user.username ? user.username : "Ausbilder");

    function parseDate(value) {
        if (!value) return null;
        return new Date(value + "T00:00:00");
    }

    function getWeekNumber(date) {
        if (!date || isNaN(date)) return "-";
        const tempDate = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
        const dayNum = tempDate.getUTCDay() || 7;
        tempDate.setUTCDate(tempDate.getUTCDate() + 4 - dayNum);
        const yearStart = new Date(Date.UTC(tempDate.getUTCFullYear(), 0, 1));
        return Math.ceil((((tempDate - yearStart) / 86400000) + 1) / 7);
    }

    function formatDate(value) {
        const date = parseDate(value);
        if (!date || isNaN(date)) return "-";

        const day = String(date.getDate()).padStart(2, "0");
        const month = String(date.getMonth() + 1).padStart(2, "0");

        return day + "." + month;
    }

    const currentWeek = getWeekNumber(new Date());

    const saniCount = termineAll.filter(t => t.examType === "Sanitaeter-Pruefung").length;
    const fahrCount = termineAll.filter(t => t.examType === "Darf alleine fahren").length;
    const goalDoneCount = allUsers.filter(u => Number(u.points || 0) >= 5).length;
    const topPoints = allUsers.length > 0 ? Number(allUsers[0].points || 0) : 0;
%>

<section class="clean-dashboard-hero">
    <div>
        <span class="clean-dashboard-label">LSMD Zentrale</span>
        <h1>Willkommen zur&uuml;ck,<br><%= displayName %></h1>
        <p>
            Ausbildungstermine, Mitglieder, Dokumente und Wochenziele zentral im Blick.
        </p>

        <div class="clean-dashboard-pills">
            <span>Alle Systeme online</span>
            <span>Woche <%= currentWeek %></span>
            <% if (isAdmin) { %>
                <span>Admin-Modus</span>
            <% } %>
        </div>
    </div>

    <div class="clean-dashboard-visual">
        <div class="clean-pulse"></div>
        <div class="clean-ambulance">🚑</div>
    </div>
</section>

<section class="clean-stats-grid">
    <div class="clean-stat-card">
        <div class="clean-stat-icon red">👥</div>
        <div>
            <h2><%= allUsers.length %></h2>
            <strong>Mitglieder</strong>
            <p>Aktive Punkte-Eintr&auml;ge</p>
        </div>
    </div>

    <div class="clean-stat-card">
        <div class="clean-stat-icon blue">📅</div>
        <div>
            <h2><%= termineAll.length %></h2>
            <strong>Termine</strong>
            <p>Ausbildungen und Pr&uuml;fungen</p>
        </div>
    </div>

    <div class="clean-stat-card">
        <div class="clean-stat-icon green">✅</div>
        <div>
            <h2><%= goalDoneCount %></h2>
            <strong>Wochenziel</strong>
            <p>Mitglieder mit 5+ Punkten</p>
        </div>
    </div>

    <div class="clean-stat-card">
        <div class="clean-stat-icon yellow">🏆</div>
        <div>
            <h2><%= topPoints %></h2>
            <strong>Top Punkte</strong>
            <p>St&auml;rkster Eintrag</p>
        </div>
    </div>
</section>

<section class="clean-dashboard-grid">
    <div class="card clean-panel">
        <div class="card-header">
            <div>
                <h2>Letzte Ausbildungseintr&auml;ge</h2>
                <p class="card-subtitle">Neueste MD-Eintr&auml;ge aus Ausbildungstermine.</p>
            </div>

            <a href="/termine" class="mini-btn">Alle anzeigen</a>
        </div>

        <% if (latestTermine.length === 0) { %>
            <div class="empty-state">
                <div>📅</div>
                <h3>Keine Eintr&auml;ge vorhanden</h3>
                <% if (isAdmin) { %>
    <p>Erstelle den ersten Eintrag bei Ausbildungstermine.</p>
<% } else { %>
    <p>Noch keine Ausbildungstermine vorhanden.</p>
<% } %>
            </div>
        <% } else { %>
            <div class="clean-entry-list">
                <% latestTermine.forEach((termin) => { %>
                    <a href="/termine" class="clean-entry-row">
                        <div class="clean-entry-date">
                            <strong><%= formatDate(termin.date) %></strong>
                            <span><%= termin.time || "--:--" %></span>
                        </div>

                        <div class="clean-entry-main">
                            <h3><%= termin.name || "Unbekannt" %></h3>
                            <p>Ausbilder: <%= termin.examiner || "Nicht eingetragen" %></p>
                        </div>

                        <% if (termin.examType === "Darf alleine fahren") { %>
                            <span class="badge blue">Fahrfreigabe</span>
                        <% } else { %>
                            <span class="badge success">Sanit&auml;ter</span>
                        <% } %>
                    </a>
                <% }) %>
            </div>
        <% } %>
    </div>

    <div class="card clean-panel">
        <div class="card-header">
            <div>
                <h2>Schnellzugriff</h2>
                <p class="card-subtitle">Direkt zu den wichtigsten Bereichen.</p>
            </div>
        </div>

        <div class="clean-quick-grid">
            <a href="/users" class="clean-quick-card red">
                <div>
                    <strong>Mitglieder</strong>
                    <span>Punkte und Wochenziel</span>
                </div>
                <b>&rsaquo;</b>
            </a>

            <a href="/termine" class="clean-quick-card blue">
                <div>
                    <% if (isAdmin) { %>
    <span>MD-Eintr&auml;ge verwalten</span>
<% } else { %>
    <span>MD-Eintr&auml;ge ansehen</span>
<% } %>
                </div>
                <b>&rsaquo;</b>
            </a>

            <a href="/dokumente" class="clean-quick-card yellow">
                <div>
                    <strong>Dokumente</strong>
                    <span>Leitf&auml;den und Regelwerke</span>
                </div>
                <b>&rsaquo;</b>
            </a>

            <% if (isAdmin) { %>
                <a href="/admin" class="clean-quick-card green">
                    <div>
                        <strong>Admin</strong>
                        <span>Leitungsbereich &ouml;ffnen</span>
                    </div>
                    <b>&rsaquo;</b>
                </a>
            <% } %>
        </div>
    </div>
</section>

<section class="clean-dashboard-grid">
    <div class="card clean-panel">
        <div class="card-header">
            <div>
                <h2>Top Mitglieder</h2>
                <p class="card-subtitle">Mitglieder mit den meisten Punkten.</p>
            </div>

            <a href="/users" class="mini-btn">Alle anzeigen</a>
        </div>

        <% if (allUsers.length === 0) { %>
            <div class="empty-state">
                <div>👥</div>
                <h3>Keine Mitglieder vorhanden</h3>
                <p>Sobald Punkte vergeben werden, erscheinen Mitglieder hier.</p>
            </div>
        <% } else { %>
            <div class="clean-member-list">
                <% allUsers.slice(0, 5).forEach((member, index) => { %>
                    <div class="clean-member-row">
                        <span class="clean-rank">
                            <% if (index === 0) { %>
                                🏆
                            <% } else { %>
                                #<%= index + 1 %>
                            <% } %>
                        </span>

                        <div>
                            <strong><%= member.displayName || member.username || member.userId || "Unbekannt" %></strong>
                            <p><%= member.rank || "Kein Rang" %></p>
                        </div>

                        <b><%= member.points || 0 %> P</b>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <div class="card clean-panel">
        <div class="card-header">
            <div>
                <h2>&Uuml;bersicht</h2>
                <p class="card-subtitle">Kurzer Stand vom Ausbildungssystem.</p>
            </div>
            <span class="chip green">Aktiv</span>
        </div>

        <div class="clean-status-list">
            <div>
                <span>Sanit&auml;ter-Pr&uuml;fungen</span>
                <strong><%= saniCount %></strong>
            </div>

            <div>
                <span>Fahrfreigaben</span>
                <strong><%= fahrCount %></strong>
            </div>

            <div>
                <span>Dokumente</span>
                <strong><%= docsAll.length %></strong>
            </div>

            <div>
                <span>Wochenziel erreicht</span>
                <strong><%= goalDoneCount %> / <%= allUsers.length %></strong>
            </div>
        </div>
    </div>
</section>