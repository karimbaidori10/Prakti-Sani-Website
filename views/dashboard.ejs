<section class="hero">
    <small>Willkommen zurück,</small>
    <h1><%= user && user.username ? user.username : "Leitung" %> 👋</h1>
    <p>Gut, dass du wieder da bist. Hier ist die aktuelle Lage deiner Prakti-Sani Verwaltung.</p>

    <div class="status-pill">
        <span class="online-dot"></span>
        Alle Systeme online
    </div>
</section>

<section class="stats-grid">
    <div class="stat-card stat-red">
        <div class="stat-icon">👥</div>
        <div>
            <h2><%= users ? users.length : 0 %></h2>
            <strong>Mitglieder</strong>
            <p>Aktive Mitglieder</p>
        </div>
    </div>

    <div class="stat-card stat-blue">
        <div class="stat-icon">📅</div>
        <div>
            <h2><%= termine ? termine.length : 0 %></h2>
            <strong>Termine</strong>
            <p>Nächste Termine</p>
        </div>
    </div>

    <div class="stat-card stat-green">
        <div class="stat-icon">📋</div>
        <div>
            <h2><%= exams ? exams.length : 0 %></h2>
            <strong>Prüfungen</strong>
            <p>Gesamt Prüfungen</p>
        </div>
    </div>

    <div class="stat-card stat-yellow">
        <div class="stat-icon">📁</div>
        <div>
            <h2>0</h2>
            <strong>Dokumente</strong>
            <p>Gespeicherte Dateien</p>
        </div>
    </div>
</section>

<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h2>📅 Nächste Termine</h2>
            <a href="/termine" class="mini-btn">Alle anzeigen</a>
        </div>

        <div class="event-list">
            <% if (termine && termine.length > 0) { %>
                <% termine.forEach(termin => { %>
                    <div class="event-item">
                        <div class="date-box">
                            <strong><%= termin.date ? new Date(termin.date).getDate() : "--" %></strong>
                            <span>
                                <%= termin.date ? new Date(termin.date).toLocaleString("de-DE", { month: "short" }).toUpperCase() : "DAT" %>
                            </span>
                        </div>

                        <div>
                            <h3><%= termin.examType || termin.name || "Termin" %></h3>
                            <p>🕒 <%= termin.time || "--:--" %> Uhr · 📍 LSMD Base</p>
                        </div>

                        <span class="chip blue"><%= termin.status || "Offen" %></span>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="event-item">
                    <div class="date-box">
                        <strong>--</strong>
                        <span>---</span>
                    </div>

                    <div>
                        <h3>Keine Termine vorhanden</h3>
                        <p>Lege neue Termine im Bereich Termine an.</p>
                    </div>

                    <span class="chip yellow">Leer</span>
                </div>
            <% } %>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>⚡ Schnellzugriff</h2>
        </div>

        <div class="quick-grid">
            <a href="/users" class="quick-card red">
                <h3>👥 Mitglieder</h3>
                <p>Benutzer verwalten</p>
            </a>

            <a href="/termine" class="quick-card blue">
                <h3>📅 Termine</h3>
                <p>Termine verwalten</p>
            </a>

            <a href="/pruefungen" class="quick-card green">
                <h3>📋 Prüfungen</h3>
                <p>Prüfungen verwalten</p>
            </a>

            <a href="/dokumente" class="quick-card yellow">
                <h3>📁 Dokumente</h3>
                <p>Dokumente verwalten</p>
            </a>
        </div>
    </div>
</section>

<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h2>📈 Letzte Prüfungen</h2>
            <a href="/pruefungen" class="mini-btn">Alle anzeigen</a>
        </div>

        <div class="activity-list">
            <% if (exams && exams.length > 0) { %>
                <% exams.forEach(exam => { %>
                    <div class="activity-item">
                        <span>📋 Prüfung erstellt: <strong><%= exam.examType %></strong> für <%= exam.name %></span>
                        <small><%= exam.result || "Offen" %></small>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="activity-item">
                    <span>Keine Prüfungen vorhanden</span>
                    <small>--</small>
                </div>
            <% } %>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>🟢 System Status</h2>
            <span class="chip green">Online</span>
        </div>

        <p>Alle Systeme funktionieren einwandfrei.</p>

        <div class="activity-list" style="margin-top: 18px;">
            <div class="activity-item">
                <span><span class="online-dot"></span> Datenbank</span>
                <small>Online</small>
            </div>

            <div class="activity-item">
                <span><span class="online-dot"></span> Web Server</span>
                <small>Online</small>
            </div>

            <div class="activity-item">
                <span><span class="online-dot"></span> MongoDB</span>
                <small>Online</small>
            </div>
        </div>
    </div>
</section>