<div class="page-header">
    <h1>Pr&uuml;fung bearbeiten</h1>
    <p>Bearbeite Teilnehmer, Pr&uuml;fungsart, Datum, Ausbilder und Notizen.</p>
</div>

<section class="card md-exam-form-card">
    <div class="card-header">
        <div>
            <h2>Pr&uuml;fungsdaten</h2>
            <p class="card-subtitle">Discord ID und Ergebnis werden hier nicht mehr ben&ouml;tigt.</p>
        </div>

        <span class="chip blue">Bearbeiten</span>
    </div>

    <form method="POST" action="/pruefungen/edit/<%= exam._id %>" class="form md-exam-form">
        <input name="name" value="<%= exam.name || '' %>" placeholder="Name des Teilnehmers" required>

        <select name="examType" required>
            <option value="">Pr&uuml;fungsart w&auml;hlen</option>

            <option value="Darf alleine fahren" <%= exam.examType === "Darf alleine fahren" ? "selected" : "" %>>
                Darf alleine fahren
            </option>

            <option value="Sanitaeter-Pruefung" <%= exam.examType === "Sanitaeter-Pruefung" ? "selected" : "" %>>
                Sanit&auml;ter-Pr&uuml;fung
            </option>
        </select>

        <div class="form-row">
            <input type="date" name="date" value="<%= exam.date || '' %>" required>
            <input type="time" name="time" value="<%= exam.time || '' %>">
        </div>

        <input name="examiner" value="<%= exam.examiner || '' %>" placeholder="Ausbilder / Pr&uuml;fer" required>

        <textarea name="notes" placeholder="Notizen zur Pr&uuml;fung"><%= exam.notes || '' %></textarea>

        <button type="submit">Speichern</button>

        <a href="/pruefungen" class="open-doc-btn">
            Abbrechen
        </a>
    </form>
</section>