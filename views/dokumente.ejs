<div class="page-header">
    <h1>Dokumente</h1>
    <p>Leitf&auml;den, Regelwerke, Checklisten und wichtige LSMD-Unterlagen zentral verwalten.</p>
</div>

<section class="dashboard-grid">
    <% if (isAdmin) { %>
        <div class="card admin-glow">
            <div class="card-header">
                <div>
                    <h2>Dokument hinzuf&uuml;gen</h2>
                    <p class="card-subtitle">Neue Unterlage oder Google-Docs-Link speichern.</p>
                </div>
                <span class="chip blue">Admin</span>
            </div>

            <form action="/dokumente/create" method="POST" class="form">
                <input type="text" name="title" placeholder="Titel des Dokuments" required>

                <select name="type" required>
                    <option value="">Kategorie ausw&auml;hlen</option>
                    <option value="LSMD Dienstblatt">LSMD Dienstblatt</option>
                    <option value="Einstellungs-Checkliste">Einstellungs-Checkliste</option>
                    <option value="Prakti darf alleine">Prakti darf alleine</option>
                    <option value="Sani Leitfaden">Sani Leitfaden</option>
                    <option value="Sanitaeter Theorie">Sanit&auml;ter Theorie</option>
                    <option value="Dienstvorschrift LSMD">Dienstvorschrift LSMD</option>
                    <option value="Prakti Sani Regelwerk">Prakti Sani Regelwerk</option>
                </select>

                <input type="url" name="url" placeholder="Dokument-Link / Google Docs Link" required>

                <textarea name="notes" placeholder="Kurze Beschreibung oder Hinweise"></textarea>

                <button type="submit">Dokument speichern</button>
            </form>
        </div>
    <% } %>

    <div class="card">
        <div class="card-header">
            <div>
                <h2>Dokumentenstatus</h2>
                <p class="card-subtitle">Aktueller Stand der gespeicherten Unterlagen.</p>
            </div>
            <span class="chip green">Live</span>
        </div>

        <div class="mini-stats">
            <div class="mini-stat">
                <strong><%= docs ? docs.length : 0 %></strong>
                <span>Gesamt</span>
            </div>

            <div class="mini-stat">
                <strong><%= docs ? docs.filter(d => d.type === "Sani Leitfaden").length : 0 %></strong>
                <span>Leitf&auml;den</span>
            </div>

            <div class="mini-stat">
                <strong><%= docs ? docs.filter(d => d.type === "Einstellungs-Checkliste").length : 0 %></strong>
                <span>Checklisten</span>
            </div>

            <div class="mini-stat">
                <strong><%= docs ? docs.filter(d => d.type === "Dienstvorschrift LSMD" || d.type === "Prakti Sani Regelwerk").length : 0 %></strong>
                <span>Regelwerke</span>
            </div>
        </div>

        <div class="clean-divider"></div>

        <div class="clean-status-list">
            <div>
                <span>Mitglieder</span>
                <strong>Nur &ouml;ffnen</strong>
            </div>

            <div>
                <span>Admins</span>
                <strong>Bearbeiten / L&ouml;schen</strong>
            </div>

            <div>
                <span>Kategorien</span>
                <strong>Aktiv</strong>
            </div>
        </div>
    </div>
</section>

<section class="card" style="margin-top: 18px;">
    <div class="card-header">
        <div>
            <h2>Gespeicherte Dokumente</h2>
            <p class="card-subtitle">Alle hinterlegten Dokumente und Links.</p>
        </div>
        <span class="chip blue"><%= docs ? docs.length : 0 %> Dokumente</span>
    </div>

<% if (docs && docs.length > 0) { %>
    <div class="pro-searchbar">
        <input
            type="text"
            id="docSearch"
            placeholder="Dokument suchen..."
            autocomplete="off"
        >

        <select id="docFilter">
            <option value="all">Alle Kategorien</option>
            <option value="leitfaden">Leitf&auml;den</option>
            <option value="checkliste">Checklisten</option>
            <option value="regelwerk">Regelwerke</option>
            <option value="theorie">Theorie</option>
            <option value="dienstblatt">Dienstblatt</option>
        </select>
    </div>
<% } %>

    <% if (!docs || docs.length === 0) { %>
        <div class="empty-state">
            <div style="font-size: 42px;">📄</div>
            <h3>Keine Dokumente gespeichert</h3>
            <p>F&uuml;ge oben dein erstes Dokument oder einen Google-Docs-Link hinzu.</p>
        </div>
    <% } else { %>
        <div class="docs-grid">
            <% docs.forEach(doc => { %>
                <%
                    const cleanType = doc.type === "Sanitaeter Theorie" ? "Sanitäter Theorie" : (doc.type || "Dokument");

                    let badgeClass = "warning";
                    let icon = "📄";

                    if (cleanType.includes("Leitfaden")) {
                        badgeClass = "blue";
                        icon = "📘";
                    }

                    if (cleanType.includes("Checkliste")) {
                        badgeClass = "green";
                        icon = "✅";
                    }

                    if (cleanType.includes("Regelwerk") || cleanType.includes("Dienstvorschrift")) {
                        badgeClass = "red";
                        icon = "⚖️";
                    }

                    if (cleanType.includes("Theorie")) {
                        badgeClass = "yellow";
                        icon = "🧠";
                    }

                    if (cleanType.includes("Dienstblatt")) {
                        badgeClass = "blue";
                        icon = "📌";
                    }
                %>

                <div
    class="doc-card"
    data-search="<%= [
        doc.title || '',
        cleanType || '',
        doc.notes || ''
    ].join(' ').toLowerCase() %>"
    data-category="<%= cleanType.toLowerCase() %>"

> 
                   <div class="doc-top">
                        <div class="doc-icon">
                            <%= icon %>
                        </div>

                        <span class="badge <%= badgeClass %>">
                            <%= cleanType %>
                        </span>
                    </div>

                    <h3><%= doc.title || "Unbenanntes Dokument" %></h3>

                    <p>
                        <%= doc.notes || "Keine Beschreibung hinterlegt." %>
                    </p>

                    <div class="doc-actions">
                        <a href="<%= doc.url %>" target="_blank" rel="noopener noreferrer" class="open-doc-btn">
                            &Ouml;ffnen
                        </a>

                        <% if (isAdmin) { %>
                            <a href="/dokumente/edit/<%= doc._id %>" class="open-doc-btn">
                                Bearbeiten
                            </a>

                            <form action="/dokumente/delete/<%= doc._id %>" method="POST">
                                <button
                                    type="submit"
                                    class="danger-btn"
                                    onclick="return confirm('Dokument wirklich l&ouml;schen?');"
                                >
                                    L&ouml;schen
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</section>

<script>
    const docSearch = document.getElementById("docSearch");
    const docFilter = document.getElementById("docFilter");
    const docCards = Array.from(document.querySelectorAll(".doc-card"));

    function filterDocs() {
        const query = (docSearch?.value || "").toLowerCase().trim();
        const filter = docFilter?.value || "all";

        let visible = 0;

        docCards.forEach(card => {
            const searchText = card.dataset.search || "";
            const category = card.dataset.category || "";

            const matchesSearch = searchText.includes(query);

            let matchesFilter = true;

            if (filter === "leitfaden") {
                matchesFilter = category.includes("leitfaden");
            }

            if (filter === "checkliste") {
                matchesFilter = category.includes("checkliste");
            }

            if (filter === "regelwerk") {
                matchesFilter = category.includes("regelwerk") || category.includes("dienstvorschrift");
            }

            if (filter === "theorie") {
                matchesFilter = category.includes("theorie");
            }

            if (filter === "dienstblatt") {
                matchesFilter = category.includes("dienstblatt");
            }

            const show = matchesSearch && matchesFilter;

            card.style.display = show ? "" : "none";

            if (show) {
                visible++;
            }
        });
    }

    if (docSearch) {
        docSearch.addEventListener("input", filterDocs);
    }

    if (docFilter) {
        docFilter.addEventListener("change", filterDocs);
    }
</script>