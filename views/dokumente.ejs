<div class="page-header">
    <h1>Dokumente</h1>
    <p>Leitf&auml;den, Regelwerke, Checklisten und wichtige LSMD-Unterlagen zentral verwalten.</p>
</div>

<section class="dashboard-grid">
    <% if (isAdmin) { %>
        <div class="card">
            <div class="card-header">
                <h2>Dokument hinzuf&uuml;gen</h2>
                <span class="chip blue">Admin</span>
            </div>

            <form action="/dokumente/create" method="POST" class="form">
                <input type="text" name="title" placeholder="Titel des Dokuments" required>

                <select name="type" required>
                    <option value="">Kategorie ausw&auml;hlen</option>
                    <option value="LSMD Dienstblatt">LSMD Dienstblatt</option>
                    <option value="Einstellungs-Checkliste">Einstellungs-Checkliste</option>
                    <option value="Prakti darf alleine">Prakti darf alleine</option>
                    <option value="Sani Leitfaden">Sani Leitfaden</option>
                    <option value="Sanitaeter Theorie">Sanit&auml;ter Theorie</option>
                    <option value="Dienstvorschrift LSMD">Dienstvorschrift LSMD</option>
                    <option value="Prakti Sani Regelwerk">Prakti Sani Regelwerk</option>
                </select>

                <input type="url" name="url" placeholder="Dokument-Link / Google Docs Link" required>

                <textarea name="notes" placeholder="Kurze Beschreibung oder Hinweise"></textarea>

                <button type="submit">Dokument speichern</button>
            </form>
        </div>
    <% } %>

    <div class="card">
        <div class="card-header">
            <h2>Dokumentenstatus</h2>
            <span class="chip green">Live</span>
        </div>

        <div class="mini-stats">
            <div class="mini-stat">
                <strong><%= docs ? docs.length : 0 %></strong>
                <span>Gesamt</span>
            </div>

            <div class="mini-stat">
                <strong><%= docs ? docs.filter(d => d.type === "Sani Leitfaden").length : 0 %></strong>
                <span>Leitf&auml;den</span>
            </div>

            <div class="mini-stat">
                <strong><%= docs ? docs.filter(d => d.type === "Einstellungs-Checkliste").length : 0 %></strong>
                <span>Checklisten</span>
            </div>

            <div class="mini-stat">
                <strong><%= docs ? docs.filter(d => d.type === "Dienstvorschrift LSMD" || d.type === "Prakti Sani Regelwerk").length : 0 %></strong>
                <span>Regelwerke</span>
            </div>
        </div>

        <div class="clean-divider"></div>

        <p style="color: var(--muted);">
            Hier kannst du LSMD-Dokumente, Google-Docs-Links, Leitf&auml;den, Regelwerke und Checklisten sammeln.
        </p>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2>Gespeicherte Dokumente</h2>
        <span class="chip blue"><%= docs ? docs.length : 0 %> Dokumente</span>
    </div>

    <% if (!docs || docs.length === 0) { %>
        <div class="empty-state">
            <div style="font-size: 42px;">Keine Dateien</div>
            <h3>Keine Dokumente gespeichert</h3>
            <p>F&uuml;ge oben dein erstes Dokument oder einen Google-Docs-Link hinzu.</p>
        </div>
    <% } else { %>
        <div class="docs-grid">
            <% docs.forEach(doc => { %>
                <div class="doc-card">
                    <div class="doc-top">
                        <div class="doc-icon">
                            Datei
                        </div>

                        <span class="badge warning">
    <% if (doc.type === "Sanitaeter Theorie") { %>
        Sanit&auml;ter Theorie
    <% } else { %>
        <%= doc.type || "Dokument" %>
    <% } %>
</span>
                    </div>

                    <h3><%= doc.title %></h3>

                    <p>
                        <%= doc.notes || "Keine Beschreibung hinterlegt." %>
                    </p>

                    <div class="doc-actions">
                        <a href="<%= doc.url %>" target="_blank" class="open-doc-btn">
                            &Ouml;ffnen
                        </a>

                        <% if (isAdmin) { %>
                            <a href="/dokumente/edit/<%= doc._id %>" class="open-doc-btn">
                                Bearbeiten
                            </a>

                            <form action="/dokumente/delete/<%= doc._id %>" method="POST">
                                <button
                                    type="submit"
                                    class="danger-btn"
                                    onclick="return confirm('Dokument wirklich l&ouml;schen?');"
                                >
                                    L&ouml;schen
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</section>