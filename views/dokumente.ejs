cd C:\Users\kbaid\Desktop\Website

@'
<div class="page-header">
    <h1>📁 Dokumente</h1>
    <p>Leitfäden, Formulare, SOPs und wichtige Unterlagen zentral verwalten.</p>
</div>

<section class="dashboard-grid">
    <% if (isAdmin) { %>
        <div class="card">
            <div class="card-header">
                <h2>➕ Dokument hinzufügen</h2>
                <span class="chip blue">Admin</span>
            </div>

            <form action="/dokumente/create" method="POST" class="form">
                <input type="text" name="title" placeholder="Titel des Dokuments" required>

                <select name="type" required>
                    <option value="">Kategorie auswählen</option>
                    <option value="Leitfaden">Leitfaden</option>
                    <option value="Formular">Formular</option>
                    <option value="SOP">SOP</option>
                    <option value="Prüfung">Prüfung</option>
                    <option value="Google Docs">Google Docs</option>
                    <option value="Sonstiges">Sonstiges</option>
                </select>

                <input type="url" name="url" placeholder="Dokument-Link / Google Docs Link" required>

                <textarea name="notes" placeholder="Kurze Beschreibung oder Hinweise"></textarea>

                <button type="submit">Dokument speichern</button>
            </form>
        </div>
    <% } %>

    <div class="card">
        <div class="card-header">
            <h2>📊 Dokumentenstatus</h2>
            <span class="chip green">Live</span>
        </div>

        <div class="mini-stats">
            <div class="mini-stat">
                <strong><%= docs ? docs.length : 0 %></strong>
                <span>Gesamt</span>
            </div>

            <div class="mini-stat">
                <strong><%= docs ? docs.filter(d => d.type === "Leitfaden").length : 0 %></strong>
                <span>Leitfäden</span>
            </div>

            <div class="mini-stat">
                <strong><%= docs ? docs.filter(d => d.type === "Formular").length : 0 %></strong>
                <span>Formulare</span>
            </div>

            <div class="mini-stat">
                <strong><%= docs ? docs.filter(d => d.type === "SOP" || d.type === "Google Docs").length : 0 %></strong>
                <span>SOP / Docs</span>
            </div>
        </div>

        <div class="clean-divider"></div>

        <p style="color: var(--muted);">
            Hier kannst du Google Docs, Leitfäden und wichtige Unterlagen sammeln.
            Später können wir automatische Google-Docs-Synchronisation einbauen.
        </p>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2>📚 Gespeicherte Dokumente</h2>
        <span class="chip blue"><%= docs ? docs.length : 0 %> Dokumente</span>
    </div>

    <% if (!docs || docs.length === 0) { %>
        <div class="empty-state">
            <div>📭</div>
            <h3>Keine Dokumente gespeichert</h3>
            <p>Füge oben dein erstes Dokument oder einen Google Docs Link hinzu.</p>
        </div>
    <% } else { %>

        <div class="docs-grid">
            <% docs.forEach(doc => { %>
                <div class="doc-card">
                    <div class="doc-top">
                        <div class="doc-icon">
                            <% if (doc.type === "Leitfaden") { %>
                                📘
                            <% } else if (doc.type === "Formular") { %>
                                📝
                            <% } else if (doc.type === "SOP") { %>
                                📕
                            <% } else if (doc.type === "Prüfung") { %>
                                📋
                            <% } else if (doc.type === "Google Docs") { %>
                                🌐
                            <% } else { %>
                                📄
                            <% } %>
                        </div>

                        <span class="badge warning"><%= doc.type || "Dokument" %></span>
                    </div>

                    <h3><%= doc.title %></h3>

                    <p>
                        <%= doc.notes || "Keine Beschreibung hinterlegt." %>
                    </p>

                    <div class="doc-actions">
                        <a href="<%= doc.url %>" target="_blank" class="open-doc-btn">
                            Öffnen
                        </a>

                        <% if (isAdmin) { %>
                            <a href="/dokumente/edit/<%= doc._id %>" class="open-doc-btn">
                                Bearbeiten
                            </a>

                            <form action="/dokumente/delete/<%= doc._id %>" method="POST">
                                <button
                                    type="submit"
                                    class="danger-btn"
                                    onclick="return confirm('Dokument wirklich löschen?');"
                                >
                                    Löschen
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

    <% } %>
</section>
'@ | Set-Content -Encoding UTF8 views\dokumente.ejs