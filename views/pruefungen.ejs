<div class="page-header">
    <h1>Pruefungen</h1>
    <p>Pruefungen erfassen, Ergebnisse verwalten und Verlauf anzeigen.</p>
</div>

<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h2>Neue Pruefung eintragen</h2>
            <span class="chip blue">Erfassung</span>
        </div>

        <form method="POST" action="/pruefungen/create" class="form">
            <input name="name" placeholder="Name des Teilnehmers" required>

            <input name="discordId" placeholder="Discord ID optional">

            <select name="examType" required>
                <option value="">Pruefungsart waehlen</option>
                <option value="Prakti-Pruefung">Prakti-Pruefung</option>
                <option value="Darf alleine fahren">Darf alleine fahren</option>
                <option value="Sanitaeter-Pruefung">Sanitaeter-Pruefung</option>
                <option value="Theorie-Pruefung">Theorie-Pruefung</option>
                <option value="Regelwerk">Regelwerk</option>
                <option value="Blaues Blatt">Blaues Blatt</option>
                <option value="Funkleitfaden">Funkleitfaden</option>
                <option value="Sonstiges">Sonstiges</option>
            </select>

            <select name="result" required>
                <option value="">Ergebnis waehlen</option>
                <option value="offen">Offen</option>
                <option value="bestanden">Bestanden</option>
                <option value="nicht bestanden">Nicht bestanden</option>
            </select>

            <input name="examiner" placeholder="Pruefer / Ausbilder">

            <textarea name="notes" placeholder="Notizen"></textarea>

            <button type="submit">Pruefung speichern</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>Pruefungsstatus</h2>
            <span class="chip green">Live</span>
        </div>

        <div class="mini-stats">
            <div class="mini-stat">
                <strong><%= exams ? exams.length : 0 %></strong>
                <span>Gesamt</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => e.result === "bestanden").length : 0 %></strong>
                <span>Bestanden</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => e.result === "nicht bestanden").length : 0 %></strong>
                <span>Nicht bestanden</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => !e.result || e.result === "offen").length : 0 %></strong>
                <span>Offen</span>
            </div>
        </div>

        <div class="clean-divider"></div>

        <p style="color: var(--muted);">
            Hier siehst du alle gespeicherten Pruefungen und deren aktuellen Stand.
        </p>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2>Pruefungsverlauf</h2>
        <span class="chip blue"><%= exams ? exams.length : 0 %> Eintraege</span>
    </div>

    <% if (!exams || exams.length === 0) { %>
        <div class="empty-state">
            <div>Keine Daten</div>
            <h3>Keine Pruefungen vorhanden</h3>
            <p>Trage oben die erste Pruefung ein.</p>
        </div>
    <% } else { %>

        <div class="activity-list">
            <% exams.forEach((exam, index) => { %>
                <div class="activity-item">
                    <div>
                        <h3><%= exam.examType || "Pruefung" %></h3>

                        <p>
                            Teilnehmer: <%= exam.name || "Unbekannt" %>
                            <% if (exam.discordId) { %>
                                - Discord ID: <%= exam.discordId %>
                            <% } %>
                        </p>

                        <p>
                            Pruefer: <%= exam.examiner || "Kein Pruefer eingetragen" %>
                        </p>

                        <% if (exam.notes) { %>
                            <p>Notiz: <%= exam.notes %></p>
                        <% } %>
                    </div>

                    <div class="termin-status">
                        <% if (exam.result === "bestanden") { %>
                            <span class="badge success">Bestanden</span>
                        <% } else if (exam.result === "nicht bestanden") { %>
                            <span class="badge danger">Nicht bestanden</span>
                        <% } else { %>
                            <span class="badge warning">Offen</span>
                        <% } %>

                        <a href="/pruefungen/edit/<%= exam._id %>" class="open-doc-btn">
                            Bearbeiten
                        </a>

                        <% if (isAdmin) { %>
                            <form method="POST" action="/pruefungen/delete/<%= exam._id %>">
                                <button type="submit" class="danger-btn" onclick="return confirm('Pruefung wirklich loeschen?');">
                                    Loeschen
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

    <% } %>
</section>