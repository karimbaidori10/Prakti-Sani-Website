<div class="page-header">
    <h1>Pr&uuml;fungen</h1>
    <p>Sanit&auml;ter-Pr&uuml;fungen erfassen, Ergebnisse dokumentieren und Verlauf anzeigen.</p>
</div>

<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h2>Sanit&auml;ter-Pr&uuml;fung eintragen</h2>
            <span class="chip blue">Erfassung</span>
        </div>

        <form method="POST" action="/pruefungen/create" class="form">
            <input name="name" placeholder="Name des Sanit&auml;ters" required>

            <input name="discordId" placeholder="Discord ID optional">

            <div class="form-row">
                <input type="date" name="date" required>
                <input type="time" name="time">
            </div>

            <input name="examiner" placeholder="Ausbilder / Pr&uuml;fer" required>

            <select name="result" required>
                <option value="">Status w&auml;hlen</option>
                <option value="Bestanden">Bestanden</option>
                <option value="Nicht bestanden">Nicht bestanden</option>
                <option value="Teilgenommen">Teilgenommen</option>
                <option value="Offen">Offen</option>
            </select>

            <textarea name="notes" placeholder="Notizen zur Pr&uuml;fung"></textarea>

            <button type="submit">Sanit&auml;ter-Pr&uuml;fung eintragen</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>Pr&uuml;fungsstatus</h2>
            <span class="chip green">Live</span>
        </div>

        <div class="mini-stats">
            <div class="mini-stat">
                <strong><%= exams ? exams.length : 0 %></strong>
                <span>Gesamt</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => e.result === "Bestanden").length : 0 %></strong>
                <span>Bestanden</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => e.result === "Nicht bestanden").length : 0 %></strong>
                <span>Nicht bestanden</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => !e.result || e.result === "Offen").length : 0 %></strong>
                <span>Offen</span>
            </div>
        </div>

        <div class="clean-divider"></div>

        <p style="color: var(--muted);">
            Hier werden Sanit&auml;ter-Pr&uuml;fungen erfasst. Jeder neue Eintrag erscheint automatisch auch bei den Ausbildungsterminen.
        </p>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2>Ausbildungstermine</h2>
        <span class="chip blue"><%= exams ? exams.length : 0 %> Eintr&auml;ge</span>
    </div>

    <% if (!exams || exams.length === 0) { %>
        <div class="empty-state">
            <div>Keine Daten</div>
            <h3>Keine Pr&uuml;fung vorhanden</h3>
            <p>Trage oben die erste Sanit&auml;ter-Pr&uuml;fung ein.</p>
        </div>
    <% } else { %>

        <div class="exam-list">
            <% exams.forEach((exam) => { %>
                <div class="exam-card">
                    <div class="exam-icon">SP</div>

                    <div class="exam-main">
                        <div class="exam-title-row">
                            <h3><%= exam.name || "Unbekannt" %></h3>

                            <% if (exam.result === "Bestanden") { %>
                                <span class="badge success">Bestanden</span>
                            <% } else if (exam.result === "Nicht bestanden") { %>
                                <span class="badge danger">Nicht bestanden</span>
                            <% } else { %>
                                <span class="badge warning"><%= exam.result || "Offen" %></span>
                            <% } %>
                        </div>

                        <p><strong>Pr&uuml;fung:</strong> Sanit&auml;ter</p>
                        <p><strong>Datum:</strong> <%= exam.date || "-" %> <%= exam.time || "" %></p>
                        <p><strong>Ausbilder:</strong> <%= exam.examiner || "-" %></p>

                        <% if (exam.discordId) { %>
                            <p><strong>Discord ID:</strong> <%= exam.discordId %></p>
                        <% } %>

                        <% if (exam.notes) { %>
                            <p class="exam-note"><strong>Notiz:</strong> <%= exam.notes %></p>
                        <% } %>
                    </div>

                    <div class="exam-actions">
                        <a href="/pruefungen/edit/<%= exam._id %>" class="open-doc-btn">
                            Bearbeiten
                        </a>

                        <% if (isAdmin) { %>
                            <form method="POST" action="/pruefungen/delete/<%= exam._id %>">
                                <button type="submit" class="danger-btn" onclick="return confirm('Pr&uuml;fung wirklich l&ouml;schen?');">
                                    L&ouml;schen
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

    <% } %>
</section>