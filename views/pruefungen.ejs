<div class="page-header">
    <h1>📋 Prüfungen</h1>
    <p>Prüfungsergebnisse eintragen, verwalten und auswerten.</p>
</div>

<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h2>➕ Prüfung eintragen</h2>
            <span class="chip blue">Neu</span>
        </div>

        <form action="/pruefungen/create" method="POST" class="form">
            <input type="text" name="name" placeholder="Name des Prüflings" required>

            <input type="text" name="discordId" placeholder="Discord ID optional">

            <select name="examType" required>
                <option value="">Prüfungsart auswählen</option>
                <option>Prakti-Sani</option>
                <option>Sani</option>
                <option>Ausbilder</option>
                <option>Nachprüfung</option>
                <option>Theorie</option>
                <option>Praxis</option>
                <option>Regelwerk</option>
                <option>Funkleitfaden</option>
            </select>

            <select name="result" required>
                <option value="">Ergebnis auswählen</option>
                <option value="Bestanden">Bestanden</option>
                <option value="Nicht bestanden">Nicht bestanden</option>
                <option value="Offen">Offen</option>
            </select>

            <input type="text" name="examiner" placeholder="Prüfer / Ausbilder">

            <textarea name="notes" placeholder="Notizen zur Prüfung"></textarea>

            <button type="submit">Prüfung speichern</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>📊 Prüfungsstatus</h2>
            <span class="chip green">Live</span>
        </div>

        <div class="mini-stats">
            <div class="mini-stat">
                <strong><%= exams ? exams.length : 0 %></strong>
                <span>Gesamt</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => e.result === "Bestanden").length : 0 %></strong>
                <span>Bestanden</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => e.result === "Nicht bestanden").length : 0 %></strong>
                <span>Nicht bestanden</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => e.result === "Offen").length : 0 %></strong>
                <span>Offen</span>
            </div>
        </div>

        <div class="clean-divider"></div>

        <p style="color: var(--muted);">
            Alle gespeicherten Prüfungen werden unten chronologisch angezeigt.
        </p>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2>📋 Prüfungsübersicht</h2>
        <span class="chip blue"><%= exams ? exams.length : 0 %> Prüfungen</span>
    </div>

    <% if (!exams || exams.length === 0) { %>
        <div class="empty-state">
            <div>📭</div>
            <h3>Keine Prüfungen vorhanden</h3>
            <p>Trage oben die erste Prüfung ein.</p>
        </div>
    <% } else { %>
        <div class="exam-list">
            <% exams.forEach(exam => { %>
                <div class="exam-card">
                    <div class="exam-main">
                        <h3><%= exam.examType || "Prüfung" %></h3>

                        <p>
                            👤 <%= exam.name || "Unbekannt" %>
                            <% if (exam.discordId) { %>
                                · 🆔 <%= exam.discordId %>
                            <% } %>
                        </p>

                        <p>
                            🧑‍🏫 <%= exam.examiner || "Kein Prüfer eingetragen" %>
                        </p>

                        <% if (exam.notes) { %>
                            <p class="termin-note">📝 <%= exam.notes %></p>
                        <% } %>

                        <% if (exam.createdAt) { %>
                            <p style="color: var(--muted); font-size: 13px;">
                                Eingetragen am <%= new Date(exam.createdAt).toLocaleDateString("de-DE") %>
                            </p>
                        <% } %>
                    </div>

                    <div class="exam-status">
                        <% if (exam.result === "Bestanden") { %>
                            <span class="badge success">Bestanden</span>
                        <% } else if (exam.result === "Nicht bestanden") { %>
                            <span class="badge danger">Nicht bestanden</span>
                        <% } else { %>
                            <span class="badge warning">Offen</span>
                        <% } %>

                        <div class="exam-actions">
                            <a href="/pruefungen/edit/<%= exam._id %>" class="open-doc-btn">
                                Bearbeiten
                            </a>

                            <% if (isAdmin) { %>
                                <form action="/pruefungen/delete/<%= exam._id %>" method="POST">
                                    <button type="submit" class="danger-btn">Löschen</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</section>
