<div class="page-header md-exam-hero">
    <div>
        <h1>Pr&uuml;fungen</h1>
        <p>MD-Pr&uuml;fungssystem f&uuml;r Fahrfreigaben und Sanit&auml;ter-Pr&uuml;fungen.</p>
    </div>

    <div class="md-exam-hero-badge">
        <strong><%= exams ? exams.length : 0 %></strong>
        <span>Eintr&auml;ge</span>
    </div>
</div>

<section class="dashboard-grid">
    <div class="card md-exam-form-card">
        <div class="card-header">
            <div>
                <h2>Pr&uuml;fung eintragen</h2>
                <p class="card-subtitle">Einfach eintragen, speichern und dokumentieren.</p>
            </div>
            <span class="chip blue">MD-System</span>
        </div>

        <form method="POST" action="/pruefungen/create" class="form md-exam-form">
            <input name="name" placeholder="Name des Teilnehmers" required>

            <select name="examType" required>
                <option value="">Pr&uuml;fungsart w&auml;hlen</option>
                <option value="Darf alleine fahren">Darf alleine fahren</option>
                <option value="Sanitaeter-Pruefung">Sanit&auml;ter-Pr&uuml;fung</option>
            </select>

            <div class="form-row">
                <input type="date" name="date" required>
                <input type="time" name="time">
            </div>

            <input name="examiner" placeholder="Ausbilder / Pr&uuml;fer" required>

            <textarea name="notes" placeholder="Notizen zur Pr&uuml;fung"></textarea>

            <button type="submit">Pr&uuml;fung speichern</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header">
            <div>
                <h2>Pr&uuml;fungsstatus</h2>
                <p class="card-subtitle">Live-&Uuml;bersicht aller gespeicherten Eintr&auml;ge.</p>
            </div>
            <span class="chip green">Live</span>
        </div>

        <div class="mini-stats">
            <div class="mini-stat">
                <strong><%= exams ? exams.length : 0 %></strong>
                <span>Gesamt</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => e.examType === "Sanitaeter-Pruefung").length : 0 %></strong>
                <span>Sanit&auml;ter</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? exams.filter(e => e.examType === "Darf alleine fahren").length : 0 %></strong>
                <span>Fahrfreigaben</span>
            </div>

            <div class="mini-stat">
                <strong><%= exams ? [...new Set(exams.map(e => e.examiner).filter(Boolean))].length : 0 %></strong>
                <span>Ausbilder</span>
            </div>
        </div>

        <div class="clean-divider"></div>

        <p style="color: var(--muted);">
            Sanit&auml;ter-Pr&uuml;fungen werden automatisch bei Ausbildungstermine dokumentiert.
            Fahrfreigaben bleiben nur im Pr&uuml;fungsverlauf.
        </p>
    </div>
</section>

<section class="card md-exam-list-card">
    <div class="card-header">
        <div>
            <h2>Pr&uuml;fungsverlauf</h2>
            <p class="card-subtitle">Alle MD-Pr&uuml;fungen sauber dokumentiert.</p>
        </div>

        <span class="chip blue"><%= exams ? exams.length : 0 %> Eintr&auml;ge</span>
    </div>

    <% if (!exams || exams.length === 0) { %>
        <div class="empty-state">
            <div>Keine Daten</div>
            <h3>Keine Pr&uuml;fungen vorhanden</h3>
            <p>Trage oben die erste Pr&uuml;fung ein.</p>
        </div>
    <% } else { %>

        <div class="md-exam-list">
            <% exams.forEach((exam) => { %>
                <div class="md-exam-row">
                    <div class="md-exam-icon">
                        <% if (exam.examType === "Darf alleine fahren") { %>
                            DF
                        <% } else { %>
                            SP
                        <% } %>
                    </div>

                    <div class="md-exam-main">
                        <div class="md-exam-top">
                            <div>
                                <h3><%= exam.name || "Unbekannt" %></h3>

                                <% if (exam.examType === "Darf alleine fahren") { %>
                                    <p>Darf alleine fahren</p>
                                <% } else { %>
                                    <p>Sanit&auml;ter-Pr&uuml;fung</p>
                                <% } %>
                            </div>

                            <% if (exam.examType === "Darf alleine fahren") { %>
                                <span class="badge blue">Fahrfreigabe</span>
                            <% } else { %>
                                <span class="badge success">Sanit&auml;ter</span>
                            <% } %>
                        </div>

                        <div class="md-exam-grid">
                            <div>
                                <span>Datum</span>
                                <strong><%= exam.date || "-" %></strong>
                            </div>

                            <div>
                                <span>Uhrzeit</span>
                                <strong><%= exam.time || "--:--" %></strong>
                            </div>

                            <div>
                                <span>Ausbilder</span>
                                <strong><%= exam.examiner || "-" %></strong>
                            </div>

                            <div>
                                <span>System</span>
                                <strong>MD</strong>
                            </div>
                        </div>

                        <% if (exam.notes) { %>
                            <div class="md-exam-note">
                                <span>Notiz</span>
                                <p><%= exam.notes %></p>
                            </div>
                        <% } %>
                    </div>

                    <div class="md-exam-actions">
                        <a href="/pruefungen/edit/<%= exam._id %>" class="open-doc-btn">
                            Bearbeiten
                        </a>

                        <% if (isAdmin) { %>
                            <form method="POST" action="/pruefungen/delete/<%= exam._id %>">
                                <button type="submit" class="danger-btn" onclick="return confirm('Pr&uuml;fung wirklich l&ouml;schen?');">
                                    L&ouml;schen
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

    <% } %>
</section>