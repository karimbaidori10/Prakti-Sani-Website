<style>
    .ow-member-grid {
        display: grid !important;
        grid-template-columns: repeat(auto-fill, minmax(430px, 1fr)) !important;
        gap: 18px !important;
        align-items: start !important;
    }

    .ow-member-card {
        position: relative !important;
        padding: 18px !important;
        border-radius: 22px !important;
        background: linear-gradient(145deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.90)) !important;
        border: 1px solid rgba(148, 163, 184, 0.22) !important;
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.35) !important;
        overflow: hidden !important;
    }

    .ow-member-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 5px;
        background: #22c55e;
    }

    .ow-member-card.ow-status-yellow::before {
        background: #facc15;
    }

    .ow-member-card.ow-status-red::before {
        background: #ef4444;
    }

    .ow-member-head {
        display: flex !important;
        justify-content: space-between !important;
        align-items: flex-start !important;
        gap: 12px !important;
        margin-bottom: 14px !important;
    }

    .ow-member-head h2 {
        margin: 8px 0 4px !important;
        font-size: 24px !important;
        line-height: 1.1 !important;
        color: #fff !important;
        font-weight: 900 !important;
    }

    .ow-member-head p {
        margin: 0 !important;
        color: rgba(226, 232, 240, 0.72) !important;
        font-size: 13px !important;
        font-weight: 700 !important;
    }

    .ow-member-count {
        min-width: 88px !important;
        padding: 10px 12px !important;
        border-radius: 16px !important;
        text-align: center !important;
        background: rgba(37, 99, 235, 0.16) !important;
        border: 1px solid rgba(96, 165, 250, 0.28) !important;
    }

    .ow-member-count strong {
        display: block !important;
        font-size: 24px !important;
        color: white !important;
        line-height: 1 !important;
    }

    .ow-member-count span {
        display: block !important;
        margin-top: 4px !important;
        font-size: 11px !important;
        color: rgba(226, 232, 240, 0.7) !important;
        font-weight: 800 !important;
    }

    .ow-mini-license-list {
        display: flex !important;
        flex-direction: column !important;
        gap: 12px !important;
    }

    .ow-mini-license {
        display: block !important;
        padding: 14px !important;
        border-radius: 18px !important;
        background: rgba(2, 6, 23, 0.42) !important;
        border: 1px solid rgba(148, 163, 184, 0.18) !important;
    }

    .ow-mini-green {
        border-color: rgba(34, 197, 94, 0.34) !important;
    }

    .ow-mini-yellow {
        border-color: rgba(250, 204, 21, 0.38) !important;
    }

    .ow-mini-red {
        border-color: rgba(239, 68, 68, 0.42) !important;
    }

    .ow-mini-main {
        display: flex !important;
        align-items: center !important;
        gap: 12px !important;
        margin-bottom: 10px !important;
    }

    .ow-mini-icon {
        width: 46px !important;
        height: 46px !important;
        min-width: 46px !important;
        border-radius: 16px !important;
        display: grid !important;
        place-items: center !important;
        background: rgba(37, 99, 235, 0.24) !important;
        border: 1px solid rgba(96, 165, 250, 0.35) !important;
        font-size: 20px !important;
    }

    .ow-mini-main strong {
        display: block !important;
        font-size: 18px !important;
        color: white !important;
        font-weight: 900 !important;
    }

    .ow-mini-main span {
        display: block !important;
        margin-top: 4px !important;
        font-size: 12px !important;
        color: rgba(226, 232, 240, 0.68) !important;
    }

    .ow-mini-status {
        display: inline-flex !important;
        width: fit-content !important;
        margin: 2px 0 10px !important;
        padding: 6px 10px !important;
        border-radius: 999px !important;
        font-size: 12px !important;
        font-weight: 900 !important;
    }

    .ow-mini-status.green {
        color: #bbf7d0 !important;
        background: rgba(34, 197, 94, 0.16) !important;
        border: 1px solid rgba(34, 197, 94, 0.36) !important;
    }

    .ow-mini-status.yellow {
        color: #fef3c7 !important;
        background: rgba(250, 204, 21, 0.16) !important;
        border: 1px solid rgba(250, 204, 21, 0.36) !important;
    }

    .ow-mini-status.red {
        color: #fecaca !important;
        background: rgba(239, 68, 68, 0.16) !important;
        border: 1px solid rgba(239, 68, 68, 0.36) !important;
    }

    .ow-mini-meta {
        display: grid !important;
        grid-template-columns: 1fr 1fr !important;
        gap: 8px !important;
        margin-top: 8px !important;
    }

    .ow-mini-meta span {
        display: block !important;
        padding: 9px 10px !important;
        border-radius: 13px !important;
        background: rgba(15, 23, 42, 0.72) !important;
        border: 1px solid rgba(148, 163, 184, 0.14) !important;
        color: rgba(226, 232, 240, 0.72) !important;
        font-size: 12px !important;
    }

    .ow-mini-meta strong {
        color: white !important;
    }

    .ow-mini-note {
        margin-top: 9px !important;
        padding: 10px 11px !important;
        border-radius: 14px !important;
        background: rgba(30, 64, 175, 0.14) !important;
        border: 1px solid rgba(59, 130, 246, 0.22) !important;
        color: rgba(226, 232, 240, 0.82) !important;
        font-size: 12px !important;
        line-height: 1.45 !important;
    }

    .ow-mini-edit {
        margin-top: 10px !important;
        border-radius: 14px !important;
        background: rgba(15, 23, 42, 0.72) !important;
        border: 1px solid rgba(148, 163, 184, 0.16) !important;
        overflow: hidden !important;
    }

    .ow-mini-edit summary {
        padding: 9px 12px !important;
        cursor: pointer !important;
        font-size: 13px !important;
        color: #e5e7eb !important;
        font-weight: 900 !important;
    }

    .ow-mini-actions {
        display: grid !important;
        grid-template-columns: 1fr 0.65fr !important;
        gap: 8px !important;
        margin-top: 10px !important;
    }

    .ow-mini-actions form {
        margin: 0 !important;
    }

    .ow-mini-actions .ow-action-btn {
        width: 100% !important;
        min-height: 36px !important;
        border-radius: 12px !important;
        font-size: 12px !important;
        font-weight: 900 !important;
    }

    @media (max-width: 900px) {
        .ow-member-grid {
            grid-template-columns: 1fr !important;
        }

        .ow-mini-meta,
        .ow-mini-actions {
            grid-template-columns: 1fr !important;
        }
    }
</style>

<section class="ow-hero">
<section class="ow-import-card">
    <div class="ow-import-head">
        <div>
            <div class="ow-kicker">Dienstblatt Import</div>
            <h2>Excel-Dienstblatt importieren</h2>
            <p>
                Lade hier das aktuelle LSMD-Dienstblatt hoch. OW, OW+ und Osprey werden automatisch übernommen.
                Alle importierten Lizenzen starten ab dem 14.06.2026 bei Tag 0.
            </p>
        </div>
    </div>

    <% if (typeof query !== "undefined" && query.import === "success") { %>
        <div class="ow-import-success">
            Import erfolgreich:
<strong><%= query.count || 0 %></strong> Mitglieder übernommen,
<strong><%= query.withLicense || 0 %></strong> Personen mit Lizenz,
<strong><%= query.withoutLicense || 0 %></strong> Personen ohne Lizenz,
<strong><%= query.licenses || 0 %></strong> einzelne Lizenzen importiert.
        </div>
    <% } %>

    <form action="/overwatch/import-dienstblatt-xlsx" method="POST" enctype="multipart/form-data" class="ow-import-form">
        <input type="file" name="dienstblattFile" accept=".xlsx,.xls" required>

        <button type="submit" class="ow-primary-btn">
            Dienstblatt importieren
        </button>
    </form>
</section>

    <div class="ow-hero-left">
        <div class="ow-kicker">LSMD • Overwatch-Abteilung</div>
        <h1>Overwatch Lizenzsystem</h1>
        <p>
            Übersicht aller Overwatch-, Overwatch+ und Osprey-Lizenzen.
            Status wird automatisch nach Ablauf berechnet.
        </p>

        <div class="ow-toolbar">
    <div class="ow-search-box">
        <input id="owSearch" type="text" placeholder="Suche nach Name, DN oder Lizenz...">
    </div>

    <div class="ow-filter-box">
        <select id="owFilter">
            <option value="all">Alle Lizenzen</option>
            <option value="Overwatch">Overwatch</option>
            <option value="Overwatch+">Overwatch+</option>
            <option value="Osprey">Osprey</option>
            <option value="red">Nur fällige</option>
        </select>
    </div>
</div>
    </div>

    <div class="ow-hero-badge">
        <strong><%= stats.total %></strong>
        <span>aktive Lizenz(en)</span>
    </div>
</section>

<section class="ow-stats">
    <div class="ow-stat-card">
        <span>👁️</span>
        <div>
            <h2><%= stats.total %></h2>
            <p>Gesamt</p>
        </div>
    </div>

    <div class="ow-stat-card green">
        <span>✅</span>
        <div>
            <h2><%= stats.green %></h2>
            <p>Gültig</p>
        </div>
    </div>

    <div class="ow-stat-card yellow">
        <span>🟡</span>
        <div>
            <h2><%= stats.yellow %></h2>
            <p>Bald fällig</p>
        </div>
    </div>

    <div class="ow-stat-card red">
        <span>🔴</span>
        <div>
            <h2><%= stats.red %></h2>
            <p>Auffrischung nötig</p>
        </div>
    </div>
</section>

<% if (canEditOverwatch) { %>
    <section class="ow-create-card">
        <div class="ow-create-head">
            <div>
                <span>➕ Neuer Eintrag</span>
                <h2>Overwatch Lizenz eintragen</h2>
                <p>Trage hier eine Lizenz direkt über die Website ein. Der Eintrag wird automatisch gespeichert.</p>
            </div>
        </div>

        <form method="POST" action="/overwatch/create" class="ow-create-form">
            <input name="dn" placeholder="Dienstnummer, z. B. MD-03" required>

            <input name="name" placeholder="Name, z. B. Prof. Dr. Kevin Fresh" required>

            <select name="licenseType" required>
                <option value="">Lizenz auswählen</option>
                <option value="Overwatch">👁️ Overwatch</option>
                <option value="Overwatch+">👁️ Overwatch+</option>
                <option value="Osprey">🦅 Osprey</option>
            </select>

            <input type="date" name="issuedAt" required>

            <select name="examiner" required>
    <option value="">Prüfer / Ausbilder auswählen</option>

    <% (overwatchExaminerOptions || []).forEach(member => { %>
        <option value="<%= member.name %>">
            <%= member.name %>
        </option>
    <% }) %>
</select>

            <textarea name="notes" placeholder="Notiz optional"></textarea>

            <button type="submit">Lizenz speichern</button>
        </form>
    </section>
<% } %>

<% const redLicenses = licenses.filter(l => l.status.key === "red"); %>

<% if (redLicenses.length > 0) { %>
    <section class="ow-alert">
        <div>
            <h2>🔴 Auffrischungen fällig</h2>
            <p>
                <strong><%= redLicenses.length %></strong> Lizenz(en) benötigen aktuell eine Auffrischungsprüfung.
            </p>
        </div>
        <span>Overwatch-Abteilung informieren</span>
    </section>
<% } %>

<section class="ow-license-grid ow-member-grid" id="owLicenseGrid">
    <% if (!licenseGroups || licenseGroups.length === 0) { %>
        <div class="ow-empty">
            <h2>Keine Lizenzen vorhanden</h2>
            <p>Importiere zuerst das Dienstblatt oder trage eine Lizenz ein.</p>
        </div>
    <% } %>

    <% (licenseGroups || []).forEach((member) => { %>
        <article
            class="ow-member-card ow-status-<%= member.statusKey %>"
            data-search="<%= `${member.dn || ''} ${member.name || ''} ${member.rank || ''} ${member.licenses.map(l => l.licenseType).join(' ')}`.toLowerCase() %>"
            data-status="<%= member.statusKey %>"
            data-license="<%= member.licenses.map(l => l.licenseType).join('|') %>"
        >
            <div class="ow-member-head">
                <div>
                    <span class="ow-dn"><%= member.dn || "Keine DN" %></span>
                    <h2><%= member.name || "Unbekannt" %></h2>
                    <% if (member.rank) { %>
                        <p><%= member.rank %></p>
                    <% } %>
                </div>

                <div class="ow-member-count">
                    <strong><%= member.licenses.length %></strong>
                    <span>Lizenz(en)</span>
                </div>
            </div>

            <div class="ow-mini-license-list">
                <% member.licenses.forEach((license) => { %>
                    <div class="ow-mini-license ow-mini-<%= license.status.key %>">
                        <div class="ow-mini-main">
                            <div class="ow-mini-icon">
                                <%= license.licenseType === "Osprey" ? "🦅" : "👁️" %>
                            </div>

                            <div>
                                <strong><%= license.licenseType %></strong>
                                <span>
                                    Seit <%= license.issuedAtFormatted %> · Fällig ab <%= license.dueDateFormatted %>
                                </span>
                            </div>
                        </div>

                        <div class="ow-mini-status <%= license.status.key %>">
                            <%= license.status.emoji %> <%= license.status.label %>
                        </div>

                        <div class="ow-mini-meta">
                            <span>Alter: <strong><%= license.status.days %> Tag(e)</strong></span>
                            <span>Prüfer: <strong><%= license.examiner || "-" %></strong></span>
                        </div>

                        <% if (license.notes) { %>
                            <div class="ow-mini-note">
                                <%= license.notes %>
                            </div>
                        <% } %>

                        <% if (canEditOverwatch) { %>
                            <details class="ow-edit-box ow-mini-edit">
                                <summary>✏️ Bearbeiten</summary>

                                <form method="POST" action="/overwatch/<%= license._id %>/update" class="ow-edit-form">
                                    <input name="dn" value="<%= license.dn || '' %>" placeholder="Dienstnummer" required>
                                    <input name="name" value="<%= license.name || '' %>" placeholder="Name" required>

                                    <select name="licenseType" required>
                                        <option value="Overwatch" <%= license.licenseType === "Overwatch" ? "selected" : "" %>>👁️ Overwatch</option>
                                        <option value="Overwatch+" <%= license.licenseType === "Overwatch+" ? "selected" : "" %>>👁️ Overwatch+</option>
                                        <option value="Osprey" <%= license.licenseType === "Osprey" ? "selected" : "" %>>🦅 Osprey</option>
                                    </select>

                                    <input type="date" name="issuedAt" value="<%= license.issuedAt ? new Date(license.issuedAt).toISOString().slice(0, 10) : '' %>" required>

                                    <select name="examiner" required>
                                        <option value="">Prüfer / Ausbilder auswählen</option>

                                        <% (overwatchExaminerOptions || []).forEach(person => { %>
                                            <option value="<%= person.name %>" <%= license.examiner === person.name ? "selected" : "" %>>
                                                <%= person.name %>
                                            </option>
                                        <% }) %>
                                    </select>

                                    <textarea name="notes" placeholder="Notiz optional"><%= license.notes || '' %></textarea>

                                    <button type="submit">Änderung speichern</button>
                                </form>
                            </details>

                            <div class="ow-mini-actions">
                                <form method="POST" action="/overwatch/<%= license._id %>/refresh">
                                    <button type="submit" class="ow-action-btn success">
                                        ✅ Diese Lizenz auffrischen
                                    </button>
                                </form>

                                <% if (isAdmin) { %>
                                    <form method="POST" action="/overwatch/<%= license._id %>/delete" onsubmit="return confirm('Diese einzelne Lizenz wirklich löschen?');">
                                        <button type="submit" class="ow-action-btn danger">
                                            🗑️ Löschen
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            </div>

            <div class="ow-card-footer">
                <span>
                    Quelle:
                    <strong>
                        <%= member.source === "discord-panel"
                            ? "Discord Panel"
                            : member.source === "dienstblatt-import"
                                ? "Dienstblatt Import"
                                : "Website"
                        %>
                    </strong>
                </span>
            </div>
        </article>
    <% }) %>
</section>

<script>
    const owFilter = document.getElementById("owFilter");
    const owSearch = document.getElementById("owSearch");
    const owCards = document.querySelectorAll(".ow-member-card");

    function applyOverwatchFilters() {
        const filter = owFilter ? owFilter.value : "all";
        const search = owSearch ? owSearch.value.toLowerCase().trim() : "";

        owCards.forEach(card => {
            const license = card.dataset.license || "";
            const status = card.dataset.status || "";
            const text = card.innerText.toLowerCase();

            const matchesFilter =
    filter === "all" ||
    license.includes(filter) ||
    status === filter;

            const matchesSearch =
                search === "" ||
                text.includes(search);

            card.style.display = matchesFilter && matchesSearch ? "" : "none";
        });
    }

    if (owFilter) {
        owFilter.addEventListener("change", applyOverwatchFilters);
    }

    if (owSearch) {
        owSearch.addEventListener("input", applyOverwatchFilters);
    }
</script>