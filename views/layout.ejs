<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>LSMD Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="app">
    <aside class="sidebar">
        <div class="brand">
            <div class="logo">LSMD</div>
            <div>
                <h2>LSMD</h2>
                <p>Punkte-System</p>
            </div>
        </div>

        <nav>
            <a class="<%= active === 'dashboard' ? 'active' : '' %>" href="/dashboard">Dashboard</a>
            <a class="<%= active === 'leaderboard' ? 'active' : '' %>" href="/leaderboard">Leaderboard</a>
            <a class="<%= active === 'users' ? 'active' : '' %>" href="/users">Mitglieder</a>
            <a class="<%= active === 'termine' ? 'active' : '' %>" href="/termine">Termine</a>
            <a class="<%= active === 'pruefungen' ? 'active' : '' %>" href="/pruefungen">Pruefungen</a>
            <a class="<%= active === 'dokumente' ? 'active' : '' %>" href="/dokumente">Dokumente</a>

            <% if (isAdmin) { %>
                <a class="<%= active === 'admin' ? 'active' : '' %>" href="/admin">Admin Panel</a>
            <% } %>
        </nav>

        <div class="sidebar-footer">
            <p><%= user?.username || "LSMD User" %></p>
            <span><%= isAdmin ? "Leitung" : "Prakti/Sani" %></span>
            <a class="logout" href="/logout">Logout</a>
        </div>
    </aside>

    <main class="content">
        <%- body %>
    </main>
</div>

<script src="/app.js"></script>
</body>
</html>
