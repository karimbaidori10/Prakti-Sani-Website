<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LSMD Dashboard</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/css/lsmd-premium.css">

    <% if (active === 'termine') { %>
    <link rel="stylesheet" href="/css/termine-ultra.css">
    <% } %>
</head>
<body>

<div class="layout">

    <aside class="sidebar">
        <div class="brand">
            <div class="brand-icon">🚑</div>
            <div>
                <h2>LSMD</h2>
                <p>Prakti-Sani System</p>
            </div>
        </div>

        <nav class="nav">

<% if (isOverwatchOnly) { %>

    <a class="<%= (typeof active !== 'undefined' && active === 'overwatch') ? 'active' : '' %>" href="/overwatch">
        <span>👁️</span>
        <strong>Overwatch</strong>
    </a>

<% } else { %>

            <a class="<%= (typeof active !== 'undefined' && active === 'dashboard') ? 'active' : '' %>" href="/dashboard">
                <span>🏠</span>
                <strong>Dashboard</strong>
            </a>

            <a class="<%= (typeof active !== 'undefined' && active === 'users') ? 'active' : '' %>" href="/users">
                <span>👥</span>
                <strong>Mitglieder</strong>
            </a>

            <a class="<%= (typeof active !== 'undefined' && active === 'termine') ? 'active' : '' %>" href="/termine">
                <span>📅</span>
                <strong>Termine</strong>
            </a>

            <a class="<%= (typeof active !== 'undefined' && active === 'dokumente') ? 'active' : '' %>" href="/dokumente">
                <span>📄</span>
                <strong>Dokumente</strong>
            </a>
            
            <% if (canEditOverwatch) { %>
    <a href="/overwatch" class="<%= active === 'overwatch' ? 'active' : '' %>">
        <span>👁️</span>
        <strong>Overwatch</strong>
    </a>
<% } %>

            <a href="/regelwerk" class="<%= active === 'regelwerk' ? 'active' : '' %>">
                <span>👥</span>
                <strong>Regelwerk</strong>
            </a>
          
                        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                <a class="<%= (typeof active !== 'undefined' && active === 'admin') ? 'active' : '' %>" href="/admin">
                    <span>🛡️</span>
                    <strong>Admin</strong>
                </a>
            <% } %>

<% } %>

        </nav>

        <div class="sidebar-bottom">
            <div class="sidebar-status-box">
                <span class="online-dot"></span>
                <div>
                    <strong>System Online</strong>
                    <p>LSMD Dashboard aktiv</p>
                </div>
            </div>

            <div class="user-card">
                <div class="avatar">
                    <% if (typeof user !== "undefined" && user && user.avatar) { %>
                        <img src="<%= user.avatar %>" alt="Avatar">
                    <% } else { %>
                        <%= (typeof user !== "undefined" && user && user.username) ? user.username.charAt(0).toUpperCase() : "L" %>
                    <% } %>
                </div>

                <div>
                    <strong><%= (typeof user !== "undefined" && user && user.username) ? user.username : "Leitung" %></strong>
                    <p>
                        <%= (typeof user !== "undefined" && user && user.role) ? user.role : "Online" %>
                    </p>
                </div>
            </div>

            <a class="logout" href="/logout">Logout</a>
        </div>
    </aside>

    <main class="main">
        <div class="topbar">
            <button class="menu-btn" type="button">☰</button>

            <div class="topbar-title">
                <strong>LSMD Ausbildungssystem</strong>
                <span>Prakti-Sani Verwaltung</span>
            </div>

            <div class="topbar-right">
                <div class="topbar-chip">
                    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                        Admin-Modus
                    <% } else { %>
                        Mitglied
                    <% } %>
                </div>

                <div class="profile-circle">
                    <% if (typeof user !== "undefined" && user && user.avatar) { %>
                        <img src="<%= user.avatar %>" alt="Avatar">
                    <% } else { %>
                        <%= (typeof user !== "undefined" && user && user.username) ? user.username.charAt(0).toUpperCase() : "L" %>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="page-content">
            <%- body %>
        </div>
    </main>

</div>

</body>
</html>