<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>LSMD Dashboard</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="layout">

    <aside class="sidebar">
        <div class="brand">
            <h2>LSMD</h2>
            <p>Prakti-Sani</p>
        </div>

        <nav>
            <a class="<%= (typeof active !== 'undefined' && active === 'dashboard') ? 'active' : '' %>" href="/dashboard">Dashboard</a>
<a class="<%= (typeof active !== 'undefined' && active === 'leaderboard') ? 'active' : '' %>" href="/leaderboard">Leaderboard</a>
<a class="<%= (typeof active !== 'undefined' && active === 'users') ? 'active' : '' %>" href="/users">Mitglieder</a>
<a class="<%= (typeof active !== 'undefined' && active === 'termine') ? 'active' : '' %>" href="/termine">Termine</a>
<a class="<%= (typeof active !== 'undefined' && active === 'pruefungen') ? 'active' : '' %>" href="/pruefungen">Prüfungen</a>
<a class="<%= (typeof active !== 'undefined' && active === 'dokumente') ? 'active' : '' %>" href="/dokumente">Dokumente</a>

<% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
    <a class="<%= (typeof active !== 'undefined' && active === 'admin') ? 'active' : '' %>" href="/admin">Admin</a>
<% } %>
        </nav>

        <a class="logout" href="/logout">Logout</a>
    </aside>

    <main class="content">
        <%- body %>
    </main>

</div>

</body>
</html>