<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <div>
                <h2>Pr&uuml;fungen & Atteste</h2>
                <p class="card-subtitle">Panels f&uuml;r Pr&uuml;fungen, Atteste und Regelwerk senden.</p>
            </div>
            <span class="chip green">Bereit</span>
        </div>

        <div class="clean-status-list">
            <div>
                <span>Spontane Pr&uuml;fung</span>
                <strong>Sanit&auml;ter Pr&uuml;fung</strong>
            </div>

            <div>
                <span>Attest-System</span>
                <strong>Panel & Ausgabe getrennt</strong>
            </div>

            <div>
                <span>Regelwerk</span>
                <strong>Embed in Discord senden</strong>
            </div>
        </div>

        <form action="/admin/spontane-panel" method="POST" style="margin-top: 16px;">
            <button type="submit">
                🚑 Spontane-Pr&uuml;fungen Panel senden
            </button>
        </form>

        <form action="/admin/attest-panel" method="POST" style="margin-top: 12px;">
            <button type="submit" class="admin-btn">
                📄 Attest-Panel senden
            </button>
        </form>
        
        <form action="/admin/overwatch-panel" method="POST" style="margin-top: 12px;">
            <button type="submit" class="admin-btn">👁️ Overwatch-Panel senden</button>
        </form>

        <form action="/admin/regelwerk-embed" method="POST" style="margin-top: 12px;">
            <button type="submit" class="admin-btn">
                📘 Regelwerk-Embed senden
            </button>
        </form>
         
        <p class="card-subtitle" style="margin-top: 12px;">
