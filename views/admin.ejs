<div class="page-header">
    <h1>Admin</h1>
    <p>Leitungsbereich f&uuml;r Punkte, Mitglieder, Logs und Systemstatus.</p>
</div>

<section class="stats-grid">
    <div class="stat-card stat-blue">
        <div class="stat-icon">US</div>
        <div>
            <h2><%= users ? users.length : 0 %></h2>
            <strong>Mitglieder</strong>
            <p>Mit Punkte-Eintrag</p>
        </div>
    </div>

    <div class="stat-card stat-green">
        <div class="stat-icon">OK</div>
        <div>
            <h2><%= users ? users.filter(u => Number(u.points || 0) >= 5).length : 0 %></h2>
            <strong>Wochenziel</strong>
            <p>Erreicht</p>
        </div>
    </div>

    <div class="stat-card stat-yellow">
        <div class="stat-icon">LG</div>
        <div>
            <h2><%= logs ? logs.length : 0 %></h2>
            <strong>Logs</strong>
            <p>Letzte Aktionen</p>
        </div>
    </div>

    <div class="stat-card stat-red">
        <div class="stat-icon">AD</div>
        <div>
            <h2>Admin</h2>
            <strong>Modus</strong>
            <p>Leitung aktiv</p>
        </div>
    </div>
</section>

<section class="dashboard-grid">
    <div class="card admin-glow">
        <div class="card-header">
            <div>
                <h2>Punkte verwalten</h2>
                <p class="card-subtitle">Punkte setzen, hinzuf&uuml;gen oder entfernen.</p>
            </div>
            <span class="chip red">Admin Tool</span>
        </div>

        <div class="points-admin-grid">
            <form action="/points/set" method="POST" class="points-box">
                <h3>Wert setzen</h3>
                <p>Punkte eines Mitglieds direkt auf einen Wert setzen.</p>

                <input type="text" name="userId" placeholder="Discord User ID" required>
                <input type="number" name="points" placeholder="Punkte" required>

                <button type="submit">Punkte setzen</button>
            </form>

            <form action="/points/add" method="POST" class="points-box">
                <h3>Punkte hinzuf&uuml;gen</h3>
                <p>Zus&auml;tzliche Punkte auf den aktuellen Stand addieren.</p>

                <input type="text" name="userId" placeholder="Discord User ID" required>
                <input type="number" name="points" placeholder="Punkte hinzuf&uuml;gen" required>

                <button type="submit">Hinzuf&uuml;gen</button>
            </form>

            <form action="/points/remove" method="POST" class="points-box danger-box">
                <h3>Punkte entfernen</h3>
                <p>Punkte abziehen, ohne unter 0 zu fallen.</p>

                <input type="text" name="userId" placeholder="Discord User ID" required>
                <input type="number" name="points" placeholder="Punkte entfernen" required>

                <button type="submit" class="danger-btn">Entfernen</button>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div>
                <h2>Schnellzugriff</h2>
                <p class="card-subtitle">Direkt zu den wichtigsten Bereichen.</p>
            </div>
            <span class="chip blue">Navigation</span>
        </div>

        <div class="quick-grid">
            <a href="/users" class="quick-card red">
                <h3>Mitglieder</h3>
                <p>Mitglieder&uuml;bersicht &ouml;ffnen</p>
            </a>

            <a href="/termine" class="quick-card blue">
                <h3>Ausbildungstermine</h3>
                <p>Eintr&auml;ge verwalten</p>
            </a>

            <a href="/dokumente" class="quick-card yellow">
                <h3>Dokumente</h3>
                <p>Unterlagen verwalten</p>
            </a>

            <a href="/dashboard" class="quick-card green">
                <h3>Dashboard</h3>
                <p>Zentrale &ouml;ffnen</p>
            </a>
        </div>
    </div>
</section>

<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <div>
                <h2>Mitglieder / Punkte</h2>
                <p class="card-subtitle">Alle Mitglieder mit Punkteverwaltung.</p>
            </div>
            <span class="chip blue"><%= users ? users.length : 0 %> Mitglieder</span>
        </div>

        <% if (!users || users.length === 0) { %>
            <div class="empty-state">
                <div>Keine Daten</div>
                <h3>Keine Mitglieder vorhanden</h3>
                <p>Sobald Punkte vergeben werden, erscheinen Mitglieder hier.</p>
            </div>
        <% } else { %>
            <div class="admin-member-list">
                <% users.forEach((member, index) => { %>
                    <div class="admin-member-row">
                        <div class="rank-number">
                            #<%= index + 1 %>
                        </div>

                        <div class="leader-avatar">
                            <% if (member.avatarUrl) { %>
                                <img src="<%= member.avatarUrl %>" alt="Avatar">
                            <% } else { %>
                                <%= (member.displayName || member.username || member.userId || "?").toString().charAt(0).toUpperCase() %>
                            <% } %>
                        </div>

                        <div>
                            <h3><%= member.displayName || member.username || member.userId || "Unbekannt" %></h3>
                            <p><%= member.rank || "Kein Rang" %></p>
                        </div>

                        <div class="leader-points">
                            <strong><%= member.points || 0 %></strong>
                            <span>Punkte</span>
                        </div>

                        <div class="points-actions">
                            <form action="/points/add" method="POST">
                                <input type="hidden" name="userId" value="<%= member.userId %>">
                                <input type="hidden" name="points" value="10">
                                <button type="submit">+10</button>
                            </form>

                            <form action="/points/remove" method="POST">
                                <input type="hidden" name="userId" value="<%= member.userId %>">
                                <input type="hidden" name="points" value="10">
                                <button type="submit" class="danger-btn">-10</button>
                            </form>

                            <form action="/points/set" method="POST">
                                <input type="hidden" name="userId" value="<%= member.userId %>">
                                <input type="number" name="points" value="<%= member.points || 0 %>" min="0">
                                <button type="submit">Setzen</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <div class="card">
        <div class="card-header">
            <div>
                <h2>Admin Logs</h2>
                <p class="card-subtitle">Letzte Aktionen im System.</p>
            </div>
            <span class="chip green"><%= logs ? logs.length : 0 %> Logs</span>
        </div>

        <% if (!logs || logs.length === 0) { %>
            <div class="empty-state">
                <div>Keine Logs</div>
                <h3>Keine Logs vorhanden</h3>
                <p>Admin-Aktionen werden hier automatisch gespeichert.</p>
            </div>
        <% } else { %>
            <div class="log-timeline">
                <% logs.forEach(log => { %>
                    <div class="log-item">
                        <div class="log-dot"></div>

                        <div>
                            <h3><%= log.action %></h3>
                            <p>
                                <%= log.createdAt ? new Date(log.createdAt).toLocaleString("de-DE") : "Kein Datum" %>
                            </p>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</section>

<section class="card clean-panel" style="margin-top: 18px;">
    <div class="card-header">
        <div>
            <h2>System Status</h2>
            <p class="card-subtitle">Aktueller Zustand der Webseite.</p>
        </div>

        <span class="chip green">Online</span>
    </div>

    <div class="clean-status-list">
        <div>
            <span>Dashboard</span>
            <strong>Online</strong>
        </div>

        <div>
            <span>Ausbildungstermine</span>
            <strong>Online</strong>
        </div>

        <div>
            <span>Mitglieder</span>
            <strong>Online</strong>
        </div>

        <div>
            <span>Dokumente</span>
            <strong>Online</strong>
        </div>

        <div>
            <span>Discord Login</span>
            <strong>Online</strong>
        </div>

        <div>
            <span>MongoDB</span>
            <strong>Online</strong>
        </div>
    </div>
</section>