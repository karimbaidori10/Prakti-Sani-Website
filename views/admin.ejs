<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <div>
                <h2>Dokumente & Webhooks</h2>
                <p class="card-subtitle">Dokumenten-&Uuml;bersichten in Discord senden.</p>
            </div>
            <span class="chip blue">Webhooks</span>
        </div>

        <form action="/admin/dokumente-webhook" method="POST" style="margin-top: 16px;">
            <button type="submit">
                📚 Dokumente-Webhook senden
            </button>
        </form>

        <form method="POST" action="/admin/professoren-dokumente-webhook" style="margin-top: 12px;">
            <button type="submit" class="btn btn-primary">
                🎓 Professoren-Dokumente senden
            </button>
        </form>

        <form action="/admin/bewerbungs-panel" method="POST" style="margin-top: 12px;">
            <button type="submit">
                🚑 Bewerbungs-Panel senden
            </button>
        </form>

        <p class="card-subtitle" style="margin-top: 12px;">
            Sendet offizielle Panels und Dokumenten-Nachrichten in die jeweiligen Discord-Channels.
        </p>
    </div>

    <div class="card admin-glow">
        <div class="card-header">
            <div>
                <h2>Wochenreset</h2>
                <p class="card-subtitle">Punkte und Bonus-System zur&uuml;cksetzen.</p>
            </div>
            <span class="chip red">Gefahr</span>
        </div>

        <div class="clean-status-list">
            <div>
                <span>Mitgliederpunkte</span>
                <strong>Werden auf 0 gesetzt</strong>
            </div>

            <div>
                <span>Einstellungsbonus</span>
