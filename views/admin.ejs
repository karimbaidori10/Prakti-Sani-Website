<div class="page-header">
    <h1>Admin</h1>
    <p>Leitungsbereich f&uuml;r Punkte, Mitglieder, Discord, Spontane Pr&uuml;fungen, Abmeldungen und Systemstatus.</p>
</div>

<section class="stats-grid">
    <div class="stat-card stat-blue">
        <div class="stat-icon">👥</div>
        <div>
            <h2><%= users ? users.length : 0 %></h2>
            <strong>Mitglieder</strong>
            <p>Mit Punkte-Eintrag</p>
        </div>
    </div>

    <div class="stat-card stat-green">
        <div class="stat-icon">🎯</div>
        <div>
            <h2><%= users ? users.filter(u => Number(u.points || 0) >= 5).length : 0 %></h2>
            <strong>Wochenziel</strong>
            <p>Mitglieder mit 5+ Punkten</p>
        </div>
    </div>

    <div class="stat-card stat-yellow">
        <div class="stat-icon">🤖</div>
        <div>
            <h2>Online</h2>
            <strong>Discord Bot</strong>
            <p>Panel & Logs bereit</p>
        </div>
    </div>

    <div class="stat-card stat-red">
        <div class="stat-icon">🛡️</div>
        <div>
            <h2>Admin</h2>
            <strong>Leitung</strong>
            <p>Vollzugriff aktiv</p>
        </div>
    </div>
</section>

<section class="dashboard-grid">
    <div class="card admin-glow">
        <div class="card-header">
            <div>
                <h2>Punkte verwalten</h2>
                <p class="card-subtitle">Punkte setzen, hinzuf&uuml;gen oder entfernen.</p>
            </div>
            <span class="chip red">Admin Tool</span>
        </div>

        <div class="points-admin-grid">
            <form action="/points/set" method="POST" class="points-box">
                <h3>Wert setzen</h3>
                <p>Punkte eines Mitglieds direkt auf einen festen Wert setzen.</p>

                <input type="text" name="userId" placeholder="Discord User ID" required>
                <input type="number" name="points" placeholder="Punkte" required>

                <button type="submit">Punkte setzen</button>
            </form>

            <form action="/points/add" method="POST" class="points-box">
                <h3>Punkte hinzuf&uuml;gen</h3>
                <p>Zus&auml;tzliche Punkte auf den aktuellen Stand addieren.</p>

                <input type="text" name="userId" placeholder="Discord User ID" required>
                <input type="number" name="points" placeholder="Punkte hinzuf&uuml;gen" required>

                <button type="submit">Hinzuf&uuml;gen</button>
            </form>

            <form action="/points/remove" method="POST" class="points-box danger-box">
                <h3>Punkte entfernen</h3>
                <p>Punkte abziehen, ohne unter 0 zu fallen.</p>

                <input type="text" name="userId" placeholder="Discord User ID" required>
                <input type="number" name="points" placeholder="Punkte entfernen" required>

                <button type="submit" class="danger-btn">Entfernen</button>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div>
                <h2>Schnellzugriff</h2>
                <p class="card-subtitle">Direkt zu den wichtigsten Bereichen.</p>
            </div>
            <span class="chip blue">Navigation</span>
        </div>

        <div class="quick-grid">
            <a href="/users" class="quick-card red">
                <h3>Mitglieder</h3>
                <p>Mitglieder&uuml;bersicht &ouml;ffnen</p>
            </a>

            <a href="/termine" class="quick-card blue">
                <h3>Termine</h3>
                <p>Ausbildungen und Pr&uuml;fungen verwalten</p>
            </a>

            <a href="/dokumente" class="quick-card yellow">
                <h3>Dokumente</h3>
                <p>Unterlagen verwalten</p>
            </a>

            <a href="/dashboard" class="quick-card green">
                <h3>Dashboard</h3>
                <p>Zentrale &ouml;ffnen</p>
            </a>
        </div>
    </div>
</section>

<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <div>
                <h2>Spontane Pr&uuml;fungen</h2>
                <p class="card-subtitle">Discord-Panel f&uuml;r spontane Sanit&auml;ter-Pr&uuml;fungen senden.</p>
            </div>
            <span class="chip green">Bereit</span>
        </div>

        <div class="clean-status-list">
            <div>
                <span>Pr&uuml;fungsart</span>
                <strong>Sanit&auml;ter Pr&uuml;fung</strong>
            </div>

            <div>
                <span>Eingabe</span>
                <strong>DN + Name per Fenster</strong>
            </div>

            <div>
                <span>Entscheidung</span>
                <strong>Leitung genehmigt / lehnt ab</strong>
            </div>

            <div>
                <span>Ablehnung</span>
                <strong>Mit Grund</strong>
            </div>
        </div>

        <form action="/admin/spontane-panel" method="POST" style="margin-top: 16px;">
            <button type="submit">
                🚑 Spontane-Pr&uuml;fungen Panel senden
            </button>
        </form>

        <p class="card-subtitle" style="margin-top: 12px;">
            Tipp: Altes Discord-Panel vorher l&ouml;schen, danach hier ein neues senden.
        </p>
    </div>

    <div class="card">
        <div class="card-header">
            <div>
                <h2>Discord</h2>
                <p class="card-subtitle">Discord-Anbindung und Loginstatus.</p>
            </div>
            <span class="chip green">Verbunden</span>
        </div>

        <div class="clean-status-list">
            <div>
                <span>Discord Login</span>
                <strong>Aktiv</strong>
            </div>

            <div>
                <span>Rollenpr&uuml;fung</span>
                <strong>Aktiv</strong>
            </div>

            <div>
                <span>Admin-Erkennung</span>
                <strong>Aktiv</strong>
            </div>

            <div>
                <span>Discord Bot</span>
                <strong>Online bei Token</strong>
            </div>

            <div>
                <span>Webhook Logs</span>
                <strong>Aktiv</strong>
            </div>
        </div>

<form action="/admin/teamliste" method="POST" style="margin-top: 16px;">
    <button type="submit">
        👥 Teamliste senden / aktualisieren
    </button>
</form>

<div class="clean-divider"></div>

<form action="/admin/wochen-reset" method="POST" style="margin-top: 16px;"
      onsubmit="return confirm('Wirklich alle Punkte auf 0 setzen? Dieser Wochenreset kann nicht automatisch rückgängig gemacht werden.');">
    <button type="submit" class="danger-btn">
        🔄 Wochenreset durchführen
    </button>
</form>

<p class="card-subtitle" style="margin-top: 12px;">
    Setzt alle Mitgliederpunkte auf <strong>0</strong>. Bitte nur am Wochenende / Reset-Zeitpunkt benutzen.
</p>

<p class="card-subtitle" style="margin-top: 12px;">
    Aktualisiert die Discord-Teamliste im Mitglieder-Channel.
</p>

<div class="clean-divider"></div>

<form action="/admin/abmeldung-panel" method="POST" style="margin-top: 16px;">
    <button type="submit">
        📨 Abmeldungs-Panel senden
    </button>
</form>

<form action="/admin/einstellungsbonus-panel" method="POST" style="margin-top: 16px;">
    <button type="submit">
        💸 Einstellungsbonus-Panel senden
    </button>
</form>

<form action="/admin/bewerbungs-panel" method="POST" style="margin-top: 16px;">
    <button type="submit">
        🚑 Bewerbungs-Panel senden
    </button>
</form>

<p class="card-subtitle" style="margin-top: 12px;">
    Sendet das Einstellungsbonus-Panel in den Bonus-HQ Channel.
</p>

<p class="card-subtitle" style="margin-top: 12px;">
    Sendet das Abmeldungs-Panel in den Discord-Abmeldungs-Channel.
</p>

    </div>
</section>

<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <div>
                <h2>Mitglieder / Punkte</h2>
                <p class="card-subtitle">Alle Mitglieder mit schneller Punkteverwaltung.</p>
            </div>
            <span class="chip blue"><%= users ? users.length : 0 %> Mitglieder</span>
        </div>

        <% if (!users || users.length === 0) { %>
            <div class="empty-state">
                <div>Keine Daten</div>
                <h3>Keine Mitglieder vorhanden</h3>
                <p>Sobald Punkte vergeben werden, erscheinen Mitglieder hier.</p>
            </div>
        <% } else { %>
            <div class="admin-member-list">
                <% users.forEach((member, index) => { %>
                    <div class="admin-member-row">
                        <div class="rank-number">
                            #<%= index + 1 %>
                        </div>

                        <div class="leader-avatar">
                            <% if (member.avatarUrl) { %>
                                <img src="<%= member.avatarUrl %>" alt="Avatar">
                            <% } else { %>
                                <%= (member.displayName || member.username || member.userId || "?").toString().charAt(0).toUpperCase() %>
                            <% } %>
                        </div>

                        <div>
                            <h3><%= member.displayName || member.username || member.userId || "Unbekannt" %></h3>
                            <p><%= member.rank || "Kein Rang" %></p>
                        </div>

                        <div class="leader-points">
                            <strong><%= member.points || 0 %></strong>
                            <span>Punkte</span>
                        </div>

                        <div class="points-actions">
                            <form action="/points/add" method="POST">
                                <input type="hidden" name="userId" value="<%= member.userId %>">
                                <input type="hidden" name="points" value="10">
                                <button type="submit">+10</button>
                            </form>

                            <form action="/points/remove" method="POST">
                                <input type="hidden" name="userId" value="<%= member.userId %>">
                                <input type="hidden" name="points" value="10">
                                <button type="submit" class="danger-btn">-10</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <div class="card clean-panel">
        <div class="card-header">
            <div>
                <h2>System Status</h2>
                <p class="card-subtitle">Aktueller Zustand der Webseite.</p>
            </div>

            <span class="chip green">Online</span>
        </div>

        <div class="clean-status-list">
            <div>
                <span>Dashboard</span>
                <strong>Online</strong>
            </div>

            <div>
                <span>Termine</span>
                <strong>Online</strong>
            </div>

            <div>
                <span>Mitglieder</span>
                <strong>Online</strong>
            </div>

            <div>
                <span>Dokumente</span>
                <strong>Online</strong>
            </div>

            <div>
                <span>Admin</span>
                <strong>Online</strong>
            </div>

            <div>
                <span>MongoDB</span>
                <strong>Verbunden</strong>
            </div>
        </div>
    </div>
</section>